{
	"extends": "@kitschpatrol/typescript-config",
	"compilerOptions": {
		// Additions and changes from Astro's strictest tsconfig
		// vs. the extended @kitschpatrol/typescript-config
		"target": "ESNext",
		"jsx": "preserve",
		"allowUnusedLabels": false,
		"exactOptionalPropertyTypes": true,
		"noImplicitOverride": true,
		"noImplicitReturns": true,
		"noUncheckedIndexedAccess": true,
		"esModuleInterop": true,
		"verbatimModuleSyntax": true
	},
	// Includes project dot-files files for typescript-eslint integration
	"include": [
		"**/*",
		"**/**.*",
		".astro/types.d.ts",
		"./playground-starlight/.astro/types.d.ts",
		"./playground/.astro/types.d.ts"
	],
	"exclude": [
		"**/dist/",
		"**/bin/",
		"**/node_modules/",
		"references/**",
		"playground/**/*.mdx",
		"playground-starlight/**/*.mdx"
	]
}
