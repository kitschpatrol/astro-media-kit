---
import aphexTest from '~aphex/Tiny/tiny'
import Picture from 'astro-media-kit/components/Picture.astro'
import testDark from '../assets/test-dark.jpeg'
import test from '../assets/test.jpeg'
import tigerDark from '../assets/tiger-dark.svg'
import tiger from '../assets/tiger.svg'
import Layout from '../layouts/Layout.astro'
import { pages } from '../pages'

const { title } = pages.find((p) => p.href === '/picture-component')!
---

<Layout {title}>
	<h1>{title}</h1>
	<p class="note">
		Toggle system dark mode to verify dark variants. Checkerboard = transparency preserved.
	</p>

	<h2>1. Dark mode (JPEG)</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>No dark</td>
				<td><Picture alt="no dark" src="../assets/test.jpeg" /></td>
				<td class="check">Same in light &amp; dark</td>
			</tr>
			<tr>
				<td>Explicit srcDark (auto-import)</td>
				<td
					><Picture
						alt="dark ai"
						src="../assets/test.jpeg"
						srcDark="../assets/test-dark.jpeg"
					/></td
				>
				<td class="check">Different image in dark</td>
			</tr>
			<tr>
				<td>Explicit srcDark (imported)</td>
				<td><Picture alt="dark imp" src={test} srcDark={testDark} /></td>
				<td class="check">Same as above</td>
			</tr>
		</tbody>
	</table>

	<h2>2. Aphex (Apple Photos)</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>Picture (auto-import)</td>
				<td><Picture alt="aphex ai" src="~aphex/Tiny/tiny" /></td>
				<td class="check">Apple Photos image</td>
			</tr>
			<tr>
				<td>Picture (imported)</td>
				<td><Picture alt="aphex imp" src={aphexTest} /></td>
				<td class="check">Same image</td>
			</tr>
		</tbody>
	</table>

	<h2>3. .tldr auto dark</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>.tldr auto dark</td>
				<td><Picture alt="tldr auto" src="../assets/test-sketch.tldr" /></td>
				<td class="check">Auto light/dark variants</td>
			</tr>
			<tr>
				<td>.tldr explicit srcDark</td>
				<td
					><Picture
						alt="tldr explicit"
						src="../assets/test-sketch.tldr"
						srcDark="../assets/test-sketch.tldr?dark=true&tldr"
					/></td
				>
				<td class="check">Same as auto</td>
			</tr>
			<tr>
				<td>.tldr srcDark={'{false}'}</td>
				<td><Picture alt="tldr disabled" src="../assets/test-sketch.tldr" srcDark={false} /></td>
				<td class="check">Light only</td>
			</tr>
		</tbody>
	</table>

	<h2>4. Background compositing</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>SVG → webp, no bg</td>
				<td class="cb"><Picture alt="svg no bg" src="../assets/tiger.svg" /></td>
				<td class="check">Transparent both modes</td>
			</tr>
			<tr>
				<td>SVG → webp, bg only</td>
				<td><Picture alt="svg bg" background="#e8e4d0" src="../assets/tiger.svg" /></td>
				<td class="check">CSS bg both modes</td>
			</tr>
			<tr>
				<td>SVG → webp, bg + bgDark</td>
				<td
					><Picture
						alt="svg bgdark webp"
						background="#e8e4d0"
						backgroundDark="#2a2520"
						src="../assets/tiger.svg"
					/></td
				>
				<td class="check">CSS light-dark() (no variant)</td>
			</tr>
			<tr>
				<td>SVG → jpg, bg only</td>
				<td
					><Picture
						alt="svg bg jpg"
						background="#e8e4d0"
						formats={['jpg']}
						src="../assets/tiger.svg"
					/></td
				>
				<td class="check">Composited beige, same both</td>
			</tr>
			<tr>
				<td>SVG → jpg, bg + bgDark</td>
				<td
					><Picture
						alt="svg bgdark jpg"
						background="#e8e4d0"
						backgroundDark="#2a2520"
						formats={['jpg']}
						src="../assets/tiger.svg"
					/></td
				>
				<td class="check">Beige (light), brown (dark)</td>
			</tr>
			<tr>
				<td>SVG → jpg, bgDark only</td>
				<td
					><Picture
						alt="svg bgdark only"
						backgroundDark="#2a2520"
						formats={['jpg']}
						src="../assets/tiger.svg"
					/></td
				>
				<td class="check">Default (light), brown (dark)</td>
			</tr>
			<tr>
				<td>SVG → jpg, same bg &amp; bgDark</td>
				<td
					><Picture
						alt="svg same"
						background="#e8e4d0"
						backgroundDark="#e8e4d0"
						formats={['jpg']}
						src="../assets/tiger.svg"
					/></td
				>
				<td class="check">Same beige (no variant)</td>
			</tr>
			<tr>
				<td>SVG → jpg, bg+bgDark, srcDark={'{false}'}</td>
				<td
					><Picture
						alt="svg disabled"
						background="#e8e4d0"
						backgroundDark="#2a2520"
						formats={['jpg']}
						src="../assets/tiger.svg"
						srcDark={false}
					/></td
				>
				<td class="check">Beige only (disabled)</td>
			</tr>
			<tr>
				<td>SVG → [webp, jpg], bg+bgDark</td>
				<td
					><Picture
						alt="svg mixed"
						background="#e8e4d0"
						backgroundDark="#2a2520"
						formats={['webp', 'jpg']}
						src="../assets/tiger.svg"
					/></td
				>
				<td class="check">Dark img for jpg, CSS for webp</td>
			</tr>
		</tbody>
	</table>

	<h2>5. SVG + explicit srcDark</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>SVG srcDark (auto-import)</td>
				<td class="cb"
					><Picture
						alt="svg dark ai"
						formats={['webp']}
						src="../assets/tiger.svg"
						srcDark="../assets/tiger-dark.svg"
					/></td
				>
				<td class="check">Tiger (light), photo (dark)</td>
			</tr>
			<tr>
				<td>SVG srcDark (imported)</td>
				<td class="cb"
					><Picture alt="svg dark imp" formats={['webp']} src={tiger} srcDark={tigerDark} /></td
				>
				<td class="check">Same as above</td>
			</tr>
		</tbody>
	</table>

	<h2>6. Layout modes</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>layout="constrained" (default via config)</td>
				<td><Picture alt="constrained default" src="../assets/test.jpeg" width={320} /></td>
				<td class="check">Scales with container</td>
			</tr>
			<tr>
				<td>layout="constrained"</td>
				<td><Picture alt="constrained" layout="constrained" src="../assets/test.jpeg" /></td>
				<td class="check">Max width capped</td>
			</tr>
			<tr>
				<td>layout="fixed"</td>
				<td><Picture alt="fixed" layout="fixed" src="../assets/test.jpeg" /></td>
				<td class="check">Fixed size, no scaling</td>
			</tr>
			<tr>
				<td>layout="full-width"</td>
				<td><Picture alt="full-width" layout="full-width" src="../assets/test.jpeg" /></td>
				<td class="check">Fills container width</td>
			</tr>
			<tr>
				<td>layout="none"</td>
				<td><Picture alt="none" layout="none" src="../assets/test.jpeg" /></td>
				<td class="check">No layout styles</td>
			</tr>
		</tbody>
	</table>

	<h2>7. Fit &amp; position</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>fit="cover"</td>
				<td
					><Picture
						alt="cover"
						fit="cover"
						layout="constrained"
						src="../assets/test.jpeg"
						widths={[160]}
					/></td
				>
				<td class="check">Cropped to fill</td>
			</tr>
			<tr>
				<td>fit="contain"</td>
				<td
					><Picture
						alt="contain"
						fit="contain"
						layout="constrained"
						src="../assets/test.jpeg"
						widths={[160]}
					/></td
				>
				<td class="check">Letterbox to fit</td>
			</tr>
			<tr>
				<td>fit="cover" position="top"</td>
				<td
					><Picture
						alt="cover top"
						fit="cover"
						layout="constrained"
						position="top"
						src="../assets/test.jpeg"
						widths={[160]}
					/></td
				>
				<td class="check">Top edge visible</td>
			</tr>
			<tr>
				<td>fit="cover" position="bottom"</td>
				<td
					><Picture
						alt="cover bottom"
						fit="cover"
						layout="constrained"
						position="bottom"
						src="../assets/test.jpeg"
						widths={[160]}
					/></td
				>
				<td class="check">Bottom edge visible</td>
			</tr>
		</tbody>
	</table>

	<h2>8. Loading &amp; decoding</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>loading="eager"</td>
				<td><Picture alt="eager" loading="eager" src="../assets/test.jpeg" /></td>
				<td class="check">No lazy attr in HTML</td>
			</tr>
			<tr>
				<td>loading="lazy" (default)</td>
				<td><Picture alt="lazy" loading="lazy" src="../assets/test.jpeg" /></td>
				<td class="check">lazy attr in HTML</td>
			</tr>
			<tr>
				<td>decoding="async" (default)</td>
				<td><Picture alt="async" decoding="async" src="../assets/test.jpeg" /></td>
				<td class="check">async attr in HTML</td>
			</tr>
			<tr>
				<td>decoding="sync"</td>
				<td><Picture alt="sync" decoding="sync" src="../assets/test.jpeg" /></td>
				<td class="check">sync attr in HTML</td>
			</tr>
		</tbody>
	</table>

	<h2>9. Densities &amp; widths</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>densities={'{[1, 2]}'}</td>
				<td><Picture alt="densities" densities={[1, 2]} src="../assets/test.jpeg" /></td>
				<td class="check">1x and 2x srcset</td>
			</tr>
			<tr>
				<td>widths={'{[100, 200, 400]}'}</td>
				<td><Picture alt="widths" src="../assets/test.jpeg" widths={[100, 200, 400]} /></td>
				<td class="check">3 widths in srcset</td>
			</tr>
			<tr>
				<td>widths + sizes</td>
				<td
					><Picture
						alt="widths sizes"
						sizes="(max-width: 400px) 100px, 200px"
						src="../assets/test.jpeg"
						widths={[100, 200]}
					/></td
				>
				<td class="check">Responsive sizes attr</td>
			</tr>
		</tbody>
	</table>

	<h2>10. Caption &amp; credit</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>creator + showCredit</td>
				<td
					><Picture
						alt="credit creator"
						captionCreator="Test Creator"
						captionShowCredit={true}
						src="../assets/test.jpeg"
					/></td
				>
				<td class="check">Credit line with creator</td>
			</tr>
			<tr>
				<td>organization + showCredit</td>
				<td
					><Picture
						alt="credit org"
						captionOrganization="Test Org"
						captionShowCredit={true}
						src="../assets/test.jpeg"
					/></td
				>
				<td class="check">Credit line with org</td>
			</tr>
			<tr>
				<td>creator + org + type</td>
				<td
					><Picture
						alt="credit full"
						captionCreator="Creator"
						captionOrganization="Org"
						captionShowCredit={true}
						captionType="photo"
						src="../assets/test.jpeg"
					/></td
				>
				<td class="check">Full credit with type</td>
			</tr>
			<tr>
				<td>typeFallback</td>
				<td
					><Picture
						alt="type fallback"
						captionShowCredit={true}
						captionTypeFallback="illustration"
						src="../assets/test.jpeg"
					/></td
				>
				<td class="check">Fallback type in credit</td>
			</tr>
			<tr>
				<td>Slot caption</td>
				<td><Picture alt="caption" src="../assets/test.jpeg">Caption text</Picture></td>
				<td class="check">Caption below picture</td>
			</tr>
		</tbody>
	</table>

	<h2>11. Zoom</h2>
	<table>
		<thead><tr><th>Scenario</th><th>Result</th><th>Expected</th></tr></thead>
		<tbody>
			<tr>
				<td>Standalone zoom</td>
				<td><Picture alt="zoom standalone" src="../assets/test.jpeg" zoom={true} /></td>
				<td class="check">Click opens lightbox</td>
			</tr>
			<tr>
				<td>Gallery zoom (1 of 2)</td>
				<td><Picture alt="gallery 1" src="../assets/test.jpeg" zoom="gallery" /></td>
				<td class="check">Click opens gallery</td>
			</tr>
			<tr>
				<td>Gallery zoom (2 of 2)</td>
				<td><Picture alt="gallery 2" src="../assets/tiger.svg" zoom="gallery" /></td>
				<td class="check">Swipe to other picture</td>
			</tr>
		</tbody>
	</table>
</Layout>
