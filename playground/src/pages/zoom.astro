---
import Image from 'astro-media-kit/components/Image.astro'
import Picture from 'astro-media-kit/components/Picture.astro'
---

<style>
	img {
		display: block;
		max-width: 160px;
		height: auto;
	}
</style>

<figure>
	<Image alt="auto jpeg" src="../assets/test.jpeg" zoom={true} />
	<figcaption>Caption</figcaption>
</figure>

<Image alt="auto jpeg" src="../assets/tiger.svg" zoom={true} />

<Picture alt="auto jpeg" src="../assets/tiger.svg" zoom={true} />

<Picture alt="auto jpeg" src="../assets/test.jpeg" zoom={true} />
