---
import Image from 'astro-media-kit/components/Image.astro'
import Picture from 'astro-media-kit/components/Picture.astro'
import Video from 'astro-media-kit/components/Video.astro'
import Zoomer from 'astro-media-kit/components/Zoomer.astro'
import Layout from '../layouts/Layout.astro'
import { pages } from '../pages'

const { title } = pages.find((p) => p.href === '/zoom')!
const bunnyId = 'f24d7806-2cf5-4df9-a340-840d68eef8c9'
---

<Layout {title}>
	<h1>{title}</h1>

	<h2>1. Single image zoom</h2>
	<p class="note">Click to open lightbox. Each item opens independently.</p>
	<div class="grid">
		<Image alt="JPEG photo" src="../assets/test.jpeg" zoom={true} />
		<Picture alt="SVG tiger" src="../assets/tiger.svg" zoom={true} />
	</div>

	<h2>2. Named gallery</h2>
	<p class="note">
		All items share <code>zoom="album"</code>. Click any to open, then swipe between them.
	</p>
	<div class="grid">
		<Picture alt="JPEG photo" src="../assets/test.jpeg" zoom="album" />
		<Image alt="SVG tiger" src="../assets/tiger.svg" zoom="album" />
		<Picture
			alt="Dark mode JPEG"
			src="../assets/test.jpeg"
			srcDark="../assets/test-dark.jpeg"
			zoom="album"
		/>
	</div>

	<h2>3. Mixed media gallery</h2>
	<p class="note">
		Images and videos share <code>zoom="mixed"</code>. Swipe between all media types.
	</p>
	<div class="grid">
		<Picture alt="JPEG photo" src="../assets/test.jpeg" zoom="mixed" zoomLevel="fill" />
		<Video
			controlStyle="full"
			initialBandwidth={50_000_000}
			src={bunnyId}
			zoom="mixed"
			zoomLevel="native"
		/>
		<Image alt="SVG tiger" src="../assets/tiger.svg" zoom="mixed" zoomLevel="fill" />
		<Video
			controlStyle="minimal"
			initialBandwidth={50_000_000}
			src={bunnyId}
			zoom="mixed"
			zoomLevel="fill"
		/>
	</div>

	<h2>4. Scoped galleries</h2>
	<p class="note">
		Both sections use <code>zoom="scoped"</code>, but <code>zoomScope=".gallery-section"</code>
		keeps them separate. Click in one section — you can only swipe within that section.
	</p>
	<div class="gallery-section">
		<h3>Section A</h3>
		<div class="grid">
			<Picture
				alt="JPEG photo"
				src="../assets/test.jpeg"
				zoom="scoped"
				zoomScope=".gallery-section"
			/>
			<Image alt="SVG tiger" src="../assets/tiger.svg" zoom="scoped" zoomScope=".gallery-section" />
		</div>
	</div>
	<div class="gallery-section">
		<h3>Section B</h3>
		<div class="grid">
			<Picture
				alt="Dark mode JPEG"
				src="../assets/test.jpeg"
				srcDark="../assets/test-dark.jpeg"
				zoom="scoped"
				zoomScope=".gallery-section"
			/>
			<Image alt="SVG tiger" src="../assets/tiger.svg" zoom="scoped" zoomScope=".gallery-section" />
		</div>
	</div>

	<h2>5. Standalone with scope</h2>
	<p class="note">
		<code>zoom=&#123;true&#125;</code> with <code>zoomScope=".scope-demo"</code> groups items under the
		same ancestor instead of opening them as standalone lightboxes.
	</p>
	<div class="scope-demo">
		<div class="grid">
			<Picture alt="JPEG photo" src="../assets/test.jpeg" zoom={true} zoomScope=".scope-demo" />
			<Image alt="SVG tiger" src="../assets/tiger.svg" zoom={true} zoomScope=".scope-demo" />
			<Picture
				alt="Dark photo"
				src="../assets/test-dark.jpeg"
				zoom={true}
				zoomScope=".scope-demo"
			/>
		</div>
	</div>

	<h2>6. Manual src</h2>
	<p class="note">TODO</p>

	<div class="grid">
		<Zoomer enabled={true} src="../assets/test.jpeg">This is just text</Zoomer>
	</div>
</Layout>

<style>
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.grid > :global(*) {
		overflow: hidden;
		min-width: 0;
	}

	.grid :global(img) {
		max-width: 100%;
		height: auto;
	}
</style>
