---
import Image from 'astro-media-kit/components/Image.astro'
import Video from 'astro-media-kit/components/Video.astro'
import Layout from '../layouts/Layout.astro'
import { pages } from '../pages'

const { title } = pages.find((p) => p.href === '/video-component')!
const bunnyId = 'f24d7806-2cf5-4df9-a340-840d68eef8c9'
---

<Layout title={title}>
	<h1>{title}</h1>

	<Video src="https://www.ted.com/talks/hans_rosling_the_best_stats_you_ve_ever_seen" />

	<h2>Control styles (HLS)</h2>
	<h3>None</h3>
	<Video
		autoPlay={true}
		capQualityToSize={false}
		controlStyle="none"
		initialBandwidth={50_000_000}
		loop={true}
		src={bunnyId}
	/>
	<h3>Minimal</h3>
	<Video
		capQualityToSize={false}
		controlStyle="minimal"
		initialBandwidth={50_000_000}
		src={bunnyId}
	/>
	<h3>Full</h3>
	<Video capQualityToSize={false} controlStyle="full" initialBandwidth={50_000_000} src={bunnyId} />
	<h3>Lightbox</h3>
	<Video controlStyle="lightbox" initialBandwidth={50_000_000} src={bunnyId} />

	<h2>Native controls</h2>
	<p>
		<code>controlStyle="native"</code> skips media-chrome and uses the underlying element's native controls
		— the service's iframe chrome for YouTube/Vimeo, the browser's built-in controls for local files and
		HLS.
	</p>
	<h3>YouTube</h3>
	<Video controlStyle="native" src="dQw4w9WgXcQ" />
	<h3>Vimeo</h3>
	<Video controlStyle="native" src="10184668" />
	<h3>Local</h3>
	<Video controlStyle="native" src="/test.mp4" />
	<h3>HLS</h3>
	<Video controlStyle="native" initialBandwidth={50_000_000} src={bunnyId} />

	<h2>Local file</h2>
	<Video src="/test.mp4" />

	<h2>Local file (with poster)</h2>
	<Video poster="/test-poster.jpeg" src="/test.mp4" />

	<h2>YouTube</h2>
	<Video src="dQw4w9WgXcQ" />

	<h2>YouTube (URL)</h2>
	<Video src="https://www.youtube.com/watch?v=dQw4w9WgXcQ" />

	<h2>YouTube (explicit service)</h2>
	<Video service="youtube" src="dQw4w9WgXcQ" />

	<h2>Vimeo</h2>
	<Video src="10184668" />

	<h2>Vimeo (URL)</h2>
	<Video src="https://vimeo.com/10184668" />

	<h2>Zoom (standalone)</h2>
	<Video controlStyle="full" initialBandwidth={50_000_000} src={bunnyId} zoom={true} />

	<h2>Zoom (mixed gallery)</h2>
	<p>Video and image in the same gallery — swipe between them.</p>
	<div style="display: flex; gap: 1rem; align-items: start;">
		<div style="flex: 1;">
			<Video
				controlStyle="full"
				initialBandwidth={50_000_000}
				src={bunnyId}
				zoom="mixed"
				zoomLevel="fill"
			/>
		</div>
		<div style="flex: 1;">
			<Image alt="test image" src="../assets/test.jpeg" zoom="mixed" zoomLevel="fill" />
		</div>
	</div>

	<h2>Playback options</h2>
	<h3>Loop + muted</h3>
	<Video loop={true} muted={true} src="/test.mp4" />
	<h3>Preload none</h3>
	<Video preload="none" src="/test.mp4" />

	<h2>Label</h2>
	<h3>Custom label</h3>
	<Video label="Test video clip" src="/test.mp4" />

	<h2>Caption &amp; credit</h2>
	<h3>Caption &amp; credit</h3>
	<Video credit="Test Creator" creditOrganization="Test Org" src="/test.mp4"
		>Video caption text</Video
	>
</Layout>
