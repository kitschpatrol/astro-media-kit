---
import {
	BUNNY_API_ACCESS_KEY,
	BUNNY_HOSTNAME,
	BUNNY_LIBRARY_ID,
	CLOUDFLARE_STREAM_ACCOUNT_ID,
	CLOUDFLARE_STREAM_API_TOKEN,
	MUX_TOKEN_ID,
	MUX_TOKEN_SECRET,
} from 'astro:env/server'
import type { Props as CaptionProps } from './Caption.astro'
import type { Service, ServiceConfig, VideoInfo } from './utils/video'
import Caption from './Caption.astro'
import { getVideoInfo, inferServiceFromMediaId } from './utils/video'

type ControlStyles = 'full' | 'minimal' | 'none'
type VideoAttributes = astroHTML.JSX.VideoHTMLAttributes

export type Props = Omit<CaptionProps, 'src'> & {
	autoPlay?: boolean
	controlStyle?: ControlStyles
	label?: string
	loop?: boolean
	muted?: boolean
	service?: Service
} & ({ mediaId: string; mediaTitle?: never } | { mediaId?: never; mediaTitle: string })

const {
	autoPlay = false,
	controlStyle = 'full',
	creator,
	mediaTitle,
	label = mediaTitle ?? 'Video',
	loop = false,
	mediaId,
	muted = true,
	organization,
	// Default service may be inferred from mediaId, but not from media title
	// Fall back to Bunny since that's what we use for most things
	service = mediaTitle === undefined ? inferServiceFromMediaId(mediaId) : 'bunny',
	showCredit = true,
	type,
	typeFallback,
} = Astro.props

const config: ServiceConfig = {
	bunny: {
		apiAccessKey: BUNNY_API_ACCESS_KEY,
		hostname: BUNNY_HOSTNAME,
		libraryId: BUNNY_LIBRARY_ID,
	},
	cloudflare: {
		accountId: CLOUDFLARE_STREAM_ACCOUNT_ID ?? '',
		apiToken: CLOUDFLARE_STREAM_API_TOKEN ?? '',
	},
	mux: {
		accessToken: MUX_TOKEN_ID ?? '',
		secret: MUX_TOKEN_SECRET ?? '',
	},
}

let videoInfo: undefined | VideoInfo
try {
	videoInfo = await getVideoInfo(mediaId ?? mediaTitle, service, config)
} catch {}

// Const { captions, height, hlsUrl, mp4Url, posterUrl, width } = videoInfo
// Const aspectRatio = width / height

const videoAttributes: VideoAttributes = {
	'aria-label': label, // From props, for accessibility
	autoplay: autoPlay || undefined, // From props
	crossorigin: 'anonymous', // Required for captions, but breaks mp4 playback in cloudflare, weird
	disablepictureinpicture: 'true',
	height: videoInfo?.height, // From video info
	loop: loop || undefined, // From props
	muted: muted || undefined, // From props
	playsinline: 'true',
	poster: videoInfo?.posterUrl, // From video info
	preload: 'auto',
	width: videoInfo?.width, // From video info
}

if (videoInfo === undefined) {
	console.error(`Video component with mediaID "${mediaId}" failed to load.`)
}

// See https://github.com/ota-meshi/typescript-eslint-parser-for-extra-files
/* eslint-disable ts/no-unsafe-assignment */
const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: undefined,
	type,
	typeFallback: typeFallback ?? 'video',
}
/* eslint-enable ts/no-unsafe-assignment */
---

<style>
	/* Never show the control bar when auto-playing, unless the video has played. */
	media-controller.autoplay:not([mediahasplayed]) media-control-bar,
	media-controller.autoplay:not([mediahasplayed]) media-play-button {
		display: none;
	}

	/* Prevent focus from scrolling content inside the player... */
	/* See https://github.com/muxinc/media-chrome/issues/1254 */
	media-controller {
		--media-time-range-hover-bottom: 0;
	}

	/* Don't hide the cursor when inactive, unless fullscreen. */
	media-controller[userinactive]:not([mediaisfullscreen]) * {
		cursor: auto !important;
	}
</style>

<script>
	import 'hls-video-element'
	import 'media-chrome'
</script>

{
	videoInfo && (
		<Caption {...captionProps}>
			<media-controller
				autohide="1"
				class:list={[controlStyle, { autoplay: autoPlay }]}
				inert={controlStyle === 'none' ? 'true' : undefined}
				slot="media-component"
			>
				<hls-video {...videoAttributes} slot="media" src={videoInfo.hlsUrl}>
					{videoInfo.captions.map((caption) => (
						<track kind="captions" {...caption} />
					))}
				</hls-video>
				{controlStyle === 'full' && (
					<media-control-bar>
						<media-play-button />
						<media-mute-button />
						<media-volume-range />
						<media-time-range />
						<media-time-display />
						{videoInfo.captions.length > 0 && <media-captions-button />}
						<media-fullscreen-button />
					</media-control-bar>
				)}
				{controlStyle === 'minimal' && (
					<media-control-bar style="justify-content: flex-end">
						<media-fullscreen-button />
					</media-control-bar>
				)}
				{controlStyle === 'minimal' && (
					<media-play-button slot="centered-chrome" style="border-radius: 50%" />
				)}
				<noscript>
					<video {...videoAttributes}>
						<source src={videoInfo.hlsUrl} type="application/x-mpegURL" />
						<source src={videoInfo.mp4Url} type="video/mp4" />
						Your browser does not support HTML5 video.
					</video>
				</noscript>
			</media-controller>
			<slot />
		</Caption>
	)
}
