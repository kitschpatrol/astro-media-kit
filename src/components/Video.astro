---
import { getSecret } from 'astro:env/server'
import type { Props as CaptionProps } from './Caption.astro'
import type { Service, ServiceConfig, VideoInfo } from './utils/video'
import Caption from './Caption.astro'
import { getVideoInfo, inferServiceFromMediaId } from './utils/video'

type ControlStyles = 'full' | 'minimal' | 'none'
type VideoAttributes = astroHTML.JSX.VideoHTMLAttributes

type SharedProps = Omit<CaptionProps, 'src'> & {
	autoPlay?: boolean
	controlStyle?: ControlStyles
	label?: string
	loop?: boolean
	muted?: boolean
	preload?: 'auto' | 'metadata' | 'none'
}

export type Props = SharedProps &
	(
		| { mediaId: string; mediaTitle?: never; poster?: never; service?: Service; src?: never }
		| { mediaId?: never; mediaTitle: string; poster?: never; service?: Service; src?: never }
		| { mediaId?: never; mediaTitle?: never; poster?: string; service?: never; src: string }
	)

const {
	autoPlay = false,
	controlStyle = 'full',
	creator,
	label,
	loop = false,
	mediaId,
	mediaTitle,
	muted = true,
	organization,
	poster,
	preload = 'metadata',
	service,
	showCredit = true,
	src,
	type,
	typeFallback,
} = Astro.props

const isLocal = src !== undefined
const resolvedService: Service | undefined = isLocal
	? undefined
	: (service ?? (mediaTitle === undefined ? inferServiceFromMediaId(mediaId) : 'bunny'))

// Resolve video info from service or local source
let videoInfo: undefined | VideoInfo

if (isLocal) {
	videoInfo = {
		captions: [],
		duration: -1,
		height: 0,
		hlsUrl: '',
		mp4Url: '',
		posterUrl: poster ?? '',
		title: label,
		width: 0,
	}
} else {
	const config: ServiceConfig = {
		bunny: {
			apiAccessKey: getSecret('BUNNY_API_ACCESS_KEY') ?? '',
			hostname: getSecret('BUNNY_HOSTNAME') ?? '',
			libraryId: getSecret('BUNNY_LIBRARY_ID') ?? '',
		},
		cloudflare: {
			accountId: getSecret('CLOUDFLARE_STREAM_ACCOUNT_ID') ?? '',
			apiToken: getSecret('CLOUDFLARE_STREAM_API_TOKEN') ?? '',
		},
		mux: {
			accessToken: getSecret('MUX_TOKEN_ID') ?? '',
			secret: getSecret('MUX_TOKEN_SECRET') ?? '',
		},
	}

	try {
		videoInfo = await getVideoInfo(mediaId ?? mediaTitle, resolvedService!, config)
	} catch (error) {
		const identifier = mediaId ?? mediaTitle
		console.error(
			`[astro-media-kit] Video "${identifier}" (${resolvedService}) failed to load:`,
			error instanceof Error ? error.message : error,
		)
	}
}

const resolvedLabel = label ?? mediaTitle ?? videoInfo?.title ?? 'Video'

const hasCaptions = (videoInfo?.captions.length ?? 0) > 0

const videoAttributes: VideoAttributes = {
	'aria-label': resolvedLabel,
	autoplay: autoPlay || undefined,
	crossorigin: resolvedService === 'cloudflare' && !hasCaptions ? undefined : 'anonymous',
	disablepictureinpicture: 'true',
	height: isLocal ? undefined : videoInfo?.height,
	loop: loop || undefined,
	muted: muted || undefined,
	playsinline: 'true',
	poster: isLocal ? (poster ?? undefined) : videoInfo?.posterUrl,
	preload,
	width: isLocal ? undefined : videoInfo?.width,
}

const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: undefined,
	type,
	typeFallback: typeFallback ?? 'video',
}

const aspectRatio =
	videoInfo?.width && videoInfo.height ? `${videoInfo.width} / ${videoInfo.height}` : undefined

// HLS-video-element extends CustomVideoElement (native <video> wrapper),
// handling HLS via hls.js, native HLS (Safari), and plain MP4/WebM sources.
const videoSrc = isLocal ? src : videoInfo?.hlsUrl
---

<style>
	/* Never show the control bar when auto-playing, unless the video has played. */
	media-controller.autoplay:not([mediahasplayed]) media-control-bar,
	media-controller.autoplay:not([mediahasplayed]) media-play-button {
		display: none;
	}

	/* Prevent focus from scrolling content inside the player... */
	/* See https://github.com/muxinc/media-chrome/issues/1254 */
	media-controller {
		--media-time-range-hover-bottom: 0;
		width: 100%;
	}

	/* Don't hide the cursor when inactive, unless fullscreen. */
	media-controller[userinactive]:not([mediaisfullscreen]) * {
		cursor: auto !important;
	}
</style>

<script>
	import 'hls-video-element'
	import 'media-chrome'
</script>

{
	videoInfo && (
		<Caption {...captionProps}>
			<media-controller
				autohide="1"
				class:list={[controlStyle, { autoplay: autoPlay }]}
				inert={controlStyle === 'none' ? 'true' : undefined}
				slot="media-component"
				style={aspectRatio ? `aspect-ratio: ${aspectRatio}` : undefined}
			>
				<hls-video {...videoAttributes} slot="media" src={videoSrc}>
					{videoInfo.captions.map((caption) => (
						<track kind="captions" {...caption} />
					))}
				</hls-video>
				{controlStyle === 'full' && (
					<media-control-bar>
						<media-play-button />
						<media-mute-button />
						<media-volume-range />
						<media-time-range />
						<media-time-display />
						{hasCaptions && <media-captions-button />}
						<media-fullscreen-button />
					</media-control-bar>
				)}
				{controlStyle === 'minimal' && (
					<media-control-bar style="justify-content: flex-end">
						<media-fullscreen-button />
					</media-control-bar>
				)}
				{controlStyle === 'minimal' && (
					<media-play-button slot="centered-chrome" style="border-radius: 50%" />
				)}
				{!isLocal && videoInfo.mp4Url && (
					<noscript>
						{/* eslint-disable-next-line astro/jsx-a11y/media-has-caption -- noscript fallback is minimal */}
						<video {...videoAttributes} crossorigin={undefined}>
							<source src={videoInfo.mp4Url} type="video/mp4" />
							Your browser does not support HTML5 video.
						</video>
					</noscript>
				)}
			</media-controller>
			<slot />
		</Caption>
	)
}
