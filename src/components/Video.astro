---
import { getSecret } from 'astro:env/server'
import type { Props as CaptionProps } from './Caption.astro'
import type { OembedInfo } from './utils/oembed'
import type { Service, ServiceConfig, VideoInfo } from './utils/video'
import Caption from './Caption.astro'
import InternalOembed from './internal/OEmbed.astro'
import VideoPlayer from './internal/VideoPlayer.astro'
import { fetchOEmbed } from './utils/oembed'
import { getVideoInfo, isEmbedService, resolveVideoSource } from './utils/video'
import Zoomer from './Zoomer.astro'

type ControlStyles = 'full' | 'lightbox' | 'minimal' | 'none'

/** Props for the `<Video>` component — unified video player supporting Bunny, Cloudflare, Mux, YouTube, Vimeo, oEmbed, and local files. */
export type Props = Omit<CaptionProps, 'src'> & {
	/**
	 * Start playback automatically (muted by default for browser autoplay policies).
	 * @default false
	 */
	autoPlay?: boolean | undefined
	/**
	 * Limit HLS quality to the element's rendered size. Saves bandwidth.
	 * @default true
	 */
	capQualityToSize?: boolean | undefined
	/**
	 * Player chrome level. `'none'` hides all controls.
	 * @default 'full'
	 */
	controlStyle?: ControlStyles | undefined
	/**
	 * Initial HLS bandwidth estimate in bits/s. Higher values start at higher quality.
	 */
	initialBandwidth?: number | undefined
	/**
	 * Accessible label for the video player. Falls back to the video title.
	 */
	label?: string | undefined
	/**
	 * Loop playback.
	 * @default false
	 */
	loop?: boolean | undefined
	/**
	 * Mute audio.
	 * @default true
	 */
	muted?: boolean | undefined
	/**
	 * Poster image URL. Overrides the service-provided thumbnail.
	 */
	poster?: string | undefined
	/**
	 * Preload behavior hint.
	 * @default 'metadata'
	 */
	preload?: 'auto' | 'metadata' | 'none' | undefined
	/**
	 * Video service override. Inferred from `src` when omitted. Required for Bunny title search.
	 */
	service?: Service | undefined
	/**
	 * Video source: a URL, raw service ID, local file path, or Bunny title string.
	 */
	src: string
	/**
	 * Enable PhotoSwipe zoom (lightbox). `true` uses default gallery, a string names the gallery.
	 * @default false
	 */
	zoom?: boolean | string | undefined
	/**
	 * CSS selector defining a gallery scope boundary. When set, galleries cannot
	 * form across matching ancestors — items under separate ancestors matching
	 * the selector become separate galleries. Ignored when `zoom` is `false`.
	 */
	zoomScope?: string | undefined
}

const {
	autoPlay = false,
	capQualityToSize,
	controlStyle = 'full',
	creator,
	initialBandwidth,
	label,
	loop = false,
	muted = true,
	organization,
	poster,
	preload = 'metadata',
	service,
	showCredit = true,
	src,
	type,
	typeFallback,
	zoom = false,
	zoomScope,
} = Astro.props

const { identifier, service: resolvedService } = resolveVideoSource(src, service)

const config: ServiceConfig = {
	bunny: {
		apiAccessKey: getSecret('BUNNY_API_ACCESS_KEY') ?? '',
		hostname: getSecret('BUNNY_HOSTNAME') ?? '',
		libraryId: getSecret('BUNNY_LIBRARY_ID') ?? '',
	},
	cloudflare: {
		accountId: getSecret('CLOUDFLARE_STREAM_ACCOUNT_ID') ?? '',
		apiToken: getSecret('CLOUDFLARE_STREAM_API_TOKEN') ?? '',
	},
	local: {},
	mux: {
		accessToken: getSecret('MUX_TOKEN_ID') ?? '',
		secret: getSecret('MUX_TOKEN_SECRET') ?? '',
	},
	oembed: {},
	vimeo: {},
	youtube: {},
}

let videoInfo: undefined | VideoInfo
let oembedInfo: OembedInfo | undefined
let fetchError: string | undefined

if (resolvedService === 'oembed') {
	try {
		oembedInfo = await fetchOEmbed(identifier)
	} catch (error) {
		fetchError = `[astro-media-kit] Video oEmbed "${identifier}" failed to load: ${error instanceof Error ? error.message : String(error)}`
		console.error(fetchError)
	}
} else {
	try {
		videoInfo = await getVideoInfo(identifier, resolvedService, config, poster ?? '')
	} catch (error) {
		fetchError = `[astro-media-kit] Video "${identifier}" (${resolvedService}) failed to load: ${error instanceof Error ? error.message : String(error)}`
		console.error(fetchError)
	}
}

const resolvedLabel = label ?? oembedInfo?.title ?? videoInfo?.title ?? 'Video'

// Compute the video source URL based on service type.
let videoSrc: string | undefined
switch (resolvedService) {
	case 'bunny': // Falls through
	case 'cloudflare': // Falls through
	case 'mux': {
		videoSrc = videoInfo?.hlsUrl
		break
	}

	case 'local': {
		videoSrc = src
		break
	}
	case 'oembed': {
		// Handled separately via fetchOEmbed
		break
	}
	case 'vimeo': {
		videoSrc = `https://vimeo.com/${identifier}`
		break
	}

	case 'youtube': {
		videoSrc = `https://www.youtube.com/watch?v=${identifier}`
		break
	}
	// No default — ts/switch-exhaustiveness-check enforces all Service cases are handled
}

const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: undefined,
	type,
	typeFallback: typeFallback ?? 'video',
}

const aspectRatio =
	videoInfo?.width && videoInfo.height ? `${videoInfo.width} / ${videoInfo.height}` : undefined
const oembedAspectRatio =
	oembedInfo?.width && oembedInfo.height ? `${oembedInfo.width} / ${oembedInfo.height}` : undefined

const hlsConfig: Record<string, boolean | number> = {}
if (initialBandwidth !== undefined) hlsConfig.abrEwmaDefaultEstimate = initialBandwidth
if (capQualityToSize !== undefined) hlsConfig.capLevelToPlayerSize = capQualityToSize

const hlsConfigJson = Object.keys(hlsConfig).length > 0 ? JSON.stringify(hlsConfig) : undefined

const posterUrl =
	resolvedService === 'local'
		? (poster ?? undefined)
		: resolvedService === 'oembed'
			? oembedInfo?.thumbnailUrl
			: videoInfo?.posterUrl

// Map service to the custom element tag name used in the lightbox.
const videoElementMap = {
	bunny: 'hls-video',
	cloudflare: 'hls-video',
	local: 'video',
	mux: 'hls-video',
	vimeo: 'vimeo-video',
	youtube: 'youtube-video',
} as const

const sharedProps = {
	aspectRatio,
	autoPlay,
	controlStyle,
	intrinsicWidth: videoInfo?.width,
	loop,
	muted,
	posterUrl,
	preload,
	resolvedLabel,
	videoSrc: videoSrc ?? '',
	zoom: Boolean(zoom),
} as const
---

<style is:global>
	/* PhotoSwipe lightbox video wrapper. Global because it renders inside
	   PhotoSwipe's DOM, outside Astro's scoped style boundary. */
	.pswp__video-wrapper media-controller {
		width: 100%;
		height: 100%;
	}
</style>

{
	fetchError ? (
		import.meta.env.DEV && <p style="font-family: monospace; color: red;">{fetchError}</p>
	) : resolvedService === 'oembed' ? (
		oembedInfo && (
			<Caption {...captionProps}>
				<InternalOembed
					aspectRatio={oembedAspectRatio}
					html={oembedInfo.html}
					resolvedLabel={resolvedLabel}
					slot="media-component"
				/>
				<slot />
			</Caption>
		)
	) : videoInfo && videoSrc ? (
		<Caption {...captionProps}>
			<Zoomer
				slot="media-component"
				videoConfig={
					!isEmbedService(resolvedService) && resolvedService !== 'local'
						? hlsConfigJson
						: undefined
				}
				videoElement={videoElementMap[resolvedService]}
				videoHeight={videoInfo.height}
				videoPoster={posterUrl}
				videoSrc={videoSrc}
				videoWidth={videoInfo.width}
				zoom={zoom}
				zoomScope={zoomScope}
			>
				<VideoPlayer
					{...sharedProps}
					captions={videoInfo.captions}
					element={videoElementMap[resolvedService]}
					hlsConfig={hlsConfig}
					hlsUrl={videoInfo.hlsUrl}
					mp4Url={videoInfo.mp4Url}
					slot="media-component"
				/>
			</Zoomer>
			<slot />
		</Caption>
	) : undefined
}
