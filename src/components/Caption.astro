---
import type { ImageMetadata } from 'astro'
import type { MediaType } from '../types'
import { getCreditFromXmpTags } from './utils/image'

const capitalize = (s: string): string => s.charAt(0).toUpperCase() + s.slice(1).toLowerCase()

export type Props = {
	/** The individual who created the image */
	creator?: string | undefined
	/** The organization to which the image is owed */
	organization?: string | undefined
	showCredit?: boolean | undefined
	/** Image source for XMP metadata lookup */
	src?: ImageMetadata | string | undefined
	type?: MediaType | undefined
	/** Fallback type if both the prop and the XMP data are undefined */
	typeFallback?: MediaType | undefined
}

const { creator, organization, showCredit = true, src, type, typeFallback } = Astro.props

// Try to resolve credit components from exif if not provided
// Note clunky rename from "credit" in the XMP tag to "organization"
// and "label" to "type"
const {
	creator: exifCreator,
	credit: exifOrganization,
	label: exifType,
} = src !== undefined &&
showCredit &&
(organization === undefined || creator === undefined || type === undefined)
	? await getCreditFromXmpTags(src)
	: { creator: undefined, credit: undefined, label: undefined }

const resolvedOrganization = organization ?? exifOrganization
const resolvedCreator = creator ?? exifCreator
const resolvedType = type ?? exifType ?? typeFallback

// Render the credit nicely

const creditLine =
	resolvedCreator !== undefined || resolvedOrganization !== undefined
		? [
				resolvedType === undefined ? undefined : capitalize(resolvedType),
				[resolvedCreator, resolvedOrganization].filter(Boolean).join(' / '),
			]
				.filter(Boolean)
				.join(': ')
		: undefined

// Can't get rid of children in markdown, so we inspect what's in the slot
const hasCaption = Boolean(
	// eslint-disable-next-line unicorn/no-await-expression-member
	Astro.slots.default && (await Astro.slots.render('default')).trim().length > 0,
)

const hasCredit = showCredit && creditLine !== undefined
---

{
	hasCaption || hasCredit ? (
		<figure>
			<slot name="media-component" />
			<figcaption>
				{hasCaption && (
					<span class="caption">
						<slot />
					</span>
				)}
				{hasCredit && <span class="credit">{creditLine}</span>}
			</figcaption>
		</figure>
	) : (
		<slot name="media-component" />
	)
}
