---
import { getSecret } from 'astro:env/server'
import type { Props as CaptionProps } from './Caption.astro'
import type { Service, ServiceConfig, VideoInfo } from './utils/video'
import Caption from './Caption.astro'
import { getVideoInfo, inferServiceFromMediaId } from './utils/video'

type ControlStyles = 'full' | 'minimal' | 'none'
type VideoAttributes = astroHTML.JSX.VideoHTMLAttributes

type SharedProps = Omit<CaptionProps, 'src'> & {
	autoPlay?: boolean
	capQualityToSize?: boolean
	controlStyle?: ControlStyles
	initialBandwidth?: number
	label?: string
	loop?: boolean
	muted?: boolean
	preload?: 'auto' | 'metadata' | 'none'
	zoom?: boolean | string | undefined
}

export type Props = SharedProps &
	(
		| { mediaId: string; mediaTitle?: never; poster?: never; service?: Service; src?: never }
		| { mediaId?: never; mediaTitle: string; poster?: never; service?: Service; src?: never }
		| { mediaId?: never; mediaTitle?: never; poster?: string; service?: never; src: string }
	)

const {
	autoPlay = false,
	capQualityToSize,
	controlStyle = 'full',
	creator,
	initialBandwidth,
	label,
	loop = false,
	mediaId,
	mediaTitle,
	muted = true,
	organization,
	poster,
	preload = 'metadata',
	service,
	showCredit = true,
	src,
	type,
	typeFallback,
	zoom = false,
} = Astro.props

const galleryName = typeof zoom === 'string' ? zoom : undefined

const isLocal = src !== undefined
const resolvedService: Service | undefined = isLocal
	? undefined
	: (service ?? (mediaTitle === undefined ? inferServiceFromMediaId(mediaId) : 'bunny'))

let videoInfo: undefined | VideoInfo

if (isLocal) {
	videoInfo = {
		captions: [],
		duration: -1,
		height: 0,
		hlsUrl: '',
		mp4Url: '',
		posterUrl: poster ?? '',
		title: label,
		width: 0,
	}
} else {
	const config: ServiceConfig = {
		bunny: {
			apiAccessKey: getSecret('BUNNY_API_ACCESS_KEY') ?? '',
			hostname: getSecret('BUNNY_HOSTNAME') ?? '',
			libraryId: getSecret('BUNNY_LIBRARY_ID') ?? '',
		},
		cloudflare: {
			accountId: getSecret('CLOUDFLARE_STREAM_ACCOUNT_ID') ?? '',
			apiToken: getSecret('CLOUDFLARE_STREAM_API_TOKEN') ?? '',
		},
		mux: {
			accessToken: getSecret('MUX_TOKEN_ID') ?? '',
			secret: getSecret('MUX_TOKEN_SECRET') ?? '',
		},
	}

	try {
		videoInfo = await getVideoInfo(mediaId ?? mediaTitle, resolvedService!, config)
	} catch (error) {
		const identifier = mediaId ?? mediaTitle
		console.error(
			`[astro-media-kit] VideoHls "${identifier}" (${resolvedService}) failed to load:`,
			error instanceof Error ? error.message : error,
		)
	}
}

const resolvedLabel = label ?? mediaTitle ?? videoInfo?.title ?? 'Video'

const videoSrc = isLocal ? src : videoInfo?.hlsUrl

const videoAttributes: VideoAttributes = {
	'aria-label': resolvedLabel,
	autoplay: autoPlay || undefined,
	crossorigin: 'anonymous',
	disablepictureinpicture: 'true',
	loop: loop || undefined,
	muted: muted || undefined,
	playsinline: 'true',
	poster: isLocal ? (poster ?? undefined) : videoInfo?.posterUrl,
	preload,
}

const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: undefined,
	type,
	typeFallback: typeFallback ?? 'video',
}

const aspectRatio =
	videoInfo?.width && videoInfo.height ? `${videoInfo.width} / ${videoInfo.height}` : undefined

const hlsConfig: Record<string, boolean | number> = {}
if (initialBandwidth !== undefined) hlsConfig.abrEwmaDefaultEstimate = initialBandwidth
if (capQualityToSize !== undefined) hlsConfig.capLevelToPlayerSize = capQualityToSize
---

<style>
	/* Never show the control bar when auto-playing, unless the video has played. */
	media-controller.autoplay:not([mediahasplayed]) media-control-bar,
	media-controller.autoplay:not([mediahasplayed]) media-play-button {
		display: none;
	}

	/* Prevent focus from scrolling content inside the player... */
	/* See https://github.com/muxinc/media-chrome/issues/1254 */
	media-controller {
		--media-time-range-hover-bottom: 0;
		width: 100%;
	}

	/* Don't hide the cursor when inactive, unless fullscreen. */
	media-controller[userinactive]:not([mediaisfullscreen]) * {
		cursor: auto !important;
	}

	/* Expand button in control bar — styled to match media-chrome buttons. */
	button.pswp-video-trigger {
		display: flex;
		align-items: center;
		justify-content: center;
		border: none;
		background: none;
		color: inherit;
		cursor: pointer;
		padding: 7px 5px;
		height: 44px;
	}

	button.pswp-video-trigger svg {
		width: 22px;
		height: 22px;
	}
</style>

<style is:global>
	/* PhotoSwipe lightbox video wrapper. Global because it renders inside
	   PhotoSwipe's DOM, outside Astro's scoped style boundary. */
	/* PhotoSwipe sets explicit width/height on content.element via
	   setDisplayedSize(). Don't override with 100% — it breaks slide
	   transition animations. The media-controller fills the wrapper. */
	.pswp__video-wrapper media-controller {
		width: 100%;
		height: 100%;
	}
</style>

<script>
	import 'hls-video-element'
	import 'media-chrome'
	import './utils/lightbox'

	import type { HlsVideoElement } from 'hls-video-element'

	// Apply hls.js config before source loading.
	// Config must be set before src so hls.js uses it during initialization.
	// Elements render with data-src instead of src, then we set config + src here.
	for (const element of document.querySelectorAll<HlsVideoElement>('hls-video[data-src]')) {
		const configAttribute = element.dataset.hlsConfig
		if (configAttribute) {
			element.config = JSON.parse(configAttribute)
		}

		element.setAttribute('src', element.dataset.src!)
	}
</script>

{
	videoInfo && (
		<Caption {...captionProps}>
			{zoom ? (
				<div
					class="pswp-zoom"
					data-pswp-gallery={galleryName}
					data-pswp-height={videoInfo.height || 1080}
					data-pswp-poster={isLocal ? (poster ?? '') : (videoInfo.posterUrl ?? '')}
					data-pswp-type="video"
					data-pswp-video-config={Object.keys(hlsConfig).length > 0 ? JSON.stringify(hlsConfig) : undefined}
					data-pswp-video-src={videoSrc}
					data-pswp-width={videoInfo.width || 1920}
					slot="media-component"
				>
					{/* eslint-disable astro/jsx-a11y/media-has-caption -- captions provided dynamically via track elements */}
					<media-controller
						autohide="1"
						class:list={[controlStyle, { autoplay: autoPlay }]}
						inert={controlStyle === 'none' ? 'true' : undefined}
						style={aspectRatio ? `aspect-ratio: ${aspectRatio}` : undefined}
					>
						<hls-video
							{...videoAttributes}
							data-hls-config={
								Object.keys(hlsConfig).length > 0
									? JSON.stringify(hlsConfig)
									: undefined
							}
							data-src={videoSrc}
							slot="media"
						>
							{videoInfo.captions.map((caption) => (
								<track kind="captions" {...caption} />
							))}
						</hls-video>
						{controlStyle === 'full' && (
							<media-control-bar>
								<media-play-button />
								<media-mute-button />
								<media-volume-range />
								<media-time-range />
								<media-time-display />
								{videoInfo.captions.length > 0 && <media-captions-button />}
								<button
									aria-label="Expand"
									class="pswp-video-trigger"
									type="button"
								>
									<svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="24">
										<path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
									</svg>
								</button>
							</media-control-bar>
						)}
						{controlStyle === 'minimal' && (
							<media-control-bar style="justify-content: flex-end">
								<button
									aria-label="Expand"
									class="pswp-video-trigger"
									type="button"
								>
									<svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" width="24">
										<path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
									</svg>
								</button>
							</media-control-bar>
						)}
						{controlStyle === 'minimal' && (
							<media-play-button
								slot="centered-chrome"
								style="border-radius: 50%"
							/>
						)}
					</media-controller>
					{/* eslint-enable astro/jsx-a11y/media-has-caption */}
				</div>
			) : (
				<>
					{/* eslint-disable astro/jsx-a11y/media-has-caption -- captions provided dynamically via track elements */}
					<media-controller
						autohide="1"
						class:list={[controlStyle, { autoplay: autoPlay }]}
						inert={controlStyle === 'none' ? 'true' : undefined}
						slot="media-component"
						style={aspectRatio ? `aspect-ratio: ${aspectRatio}` : undefined}
					>
						<hls-video
							{...videoAttributes}
							data-hls-config={
								Object.keys(hlsConfig).length > 0
									? JSON.stringify(hlsConfig)
									: undefined
							}
							data-src={videoSrc}
							slot="media"
						>
							{videoInfo.captions.map((caption) => (
								<track kind="captions" {...caption} />
							))}
						</hls-video>
						{controlStyle === 'full' && (
							<media-control-bar>
								<media-play-button />
								<media-mute-button />
								<media-volume-range />
								<media-time-range />
								<media-time-display />
								{videoInfo.captions.length > 0 && <media-captions-button />}
								<media-fullscreen-button />
							</media-control-bar>
						)}
						{controlStyle === 'minimal' && (
							<media-control-bar style="justify-content: flex-end">
								<media-fullscreen-button />
							</media-control-bar>
						)}
						{controlStyle === 'minimal' && (
							<media-play-button
								slot="centered-chrome"
								style="border-radius: 50%"
							/>
						)}
					</media-controller>
					{/* eslint-enable astro/jsx-a11y/media-has-caption */}
				</>
			)}
			{!isLocal && (
				<noscript>
					{/* eslint-disable-next-line astro/jsx-a11y/media-has-caption -- noscript fallback is minimal */}
					<video {...videoAttributes}>
						<source src={videoInfo.hlsUrl} type="application/x-mpegURL" />
						{videoInfo.mp4Url && <source src={videoInfo.mp4Url} type="video/mp4" />}
						Your browser does not support HTML5 video.
					</video>
				</noscript>
			)}
			<slot />
		</Caption>
	)
}
