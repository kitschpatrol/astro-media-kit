---
// Simple image component wrapping Astro's built-in Image.
// Accepts ImageMetadata or a string path. Does NOT support dark mode —
// use the Picture component for light/dark variants.

import type { ImageMetadata } from 'astro'
import type { LocalImageProps } from 'astro:assets'
import { Image as AstroImage } from 'astro:assets'
import type { Props as CaptionProps } from './Caption.astro'
import Caption from './Caption.astro'
import { isDarkLightImageMetadata, isImageMetadataObject, resolveImageSource } from './utils/image'

// Only use LocalImageProps since we always resolve to ImageMetadata (local images)
export type Props = Omit<CaptionProps, 'src'> &
	Omit<LocalImageProps, 'src'> & {
		src: ImageMetadata | string
	}

const {
	creator,
	organization,
	showCredit = true,
	src,
	type,
	typeFallback = 'image',
	...imageRestProps
} = Astro.props

// Resolve string paths to ImageMetadata
const resolvedImage = isImageMetadataObject(src) ? src : await resolveImageSource(src)

if (isDarkLightImageMetadata(resolvedImage)) {
	throw new Error('No light / dark mode support in Image component. Use Picture component instead.')
}

const imageMetadata = resolvedImage

const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: imageMetadata,
	type,
	typeFallback,
}

// Assemble props for AstroImage. The assertion is necessary because Astro's
// Image component accepts LocalImageProps | RemoteImageProps, and TypeScript's
// exactOptionalPropertyTypes can't reconcile spread props with union types.
// See: https://github.com/withastro/astro/issues/10780
const astroImageProps = { src: imageMetadata, ...imageRestProps } as LocalImageProps
---

<Caption {...captionProps}>
	<AstroImage {...astroImageProps} slot="media-component" />
	<slot />
</Caption>
