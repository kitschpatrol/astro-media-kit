---
// Reimplements Astro's `<Image>` component as a clean superset of the built-in:
// - Transparency-aware fallback format selection (PNG/SVG/GIF stay in-format)
// - Background compositing for opaque output formats (JPEG)
// - Caption + Zoom wrappers from the media-kit
//
// For dark-mode image sources, use `<Picture>`. When given a `{ dark, light }`
// pair, this component picks `.light` and emits a dev warning.
//
// Remote image sources are intentionally not supported — pass a local
// ImageMetadata object or an absolute file path.

import type { ImageMetadata } from 'astro'
import type { LocalImageProps } from 'astro:assets'
import type { HTMLAttributes } from 'astro/types'
import { getImage, imageConfig } from 'astro:assets'
import type { DarkLightImageMetadata, ImageMetadataLike } from '../types'
import type { Props as CaptionProps } from './Caption.astro'
import type { GetImageResult } from './utils/image-orchestration'
import Caption from './Caption.astro'
import { isDarkLightImageMetadata } from './utils/image'
import {
	buildBackgroundStyle,
	cloneImageMetadata,
	compositingBackground,
	mergeLayoutDefaults,
	pickFallbackFormat,
	resolveSizesAttribute,
	resolveSrc,
	resolveSrcToMetadata,
	warnBackgroundDarkWithoutBackground,
	warnWidthsWithoutSizes,
} from './utils/image-orchestration'
import Zoomer from './Zoomer.astro'

/**
 * Props for the `<Image>` component — renders a single `<img>` with caption and
 * zoom support. Derives from Astro's `LocalImageProps` (all getImage-compatible
 * fields like `densities`, `fit`, `height`, `layout`, `loading`, `position`,
 * `quality`, `sizes`, `width`, `widths`, plus `<img>` HTMLAttributes). Media-kit
 * extensions (`src` widening, background, caption, zoom) follow.
 */
export type Props = Omit<CaptionProps, 'src'> &
	Omit<LocalImageProps, 'height' | 'src' | 'width'> & {
		/**
		 * CSS background color for the image (visible behind transparent areas).
		 */
		background?: string | undefined
		/**
		 * Dark mode background color override. Uses `light-dark()` with `background`.
		 */
		backgroundDark?: string | undefined
		/**
		 * JSX-style class name (passed by MDX). Merged with `class`.
		 */
		className?: string | undefined
		/**
		 * Display height in pixels. Narrowed from Astro's `<img>` HTMLAttributes to
		 * numeric-only, since getImage() rejects string dimensions.
		 */
		height?: number | undefined
		/**
		 * Image source: an `ImageMetadata` object, a `{ dark, light }` pair (only
		 * `.light` is used — use `<Picture>` for dark-mode image sources), or an
		 * absolute file path string.
		 */
		src: DarkLightImageMetadata | ImageMetadata | ImageMetadataLike | string
		/**
		 * Display width in pixels. Narrowed from Astro's `<img>` HTMLAttributes to
		 * numeric-only, since getImage() rejects string dimensions.
		 */
		width?: number | undefined
		/**
		 * Enable PhotoSwipe zoom. `true` uses default gallery, a string groups into a named gallery.
		 * @default false
		 */
		zoom?: boolean | string | undefined
		/**
		 * CSS selector defining a gallery scope boundary. When set, galleries cannot
		 * form across matching ancestors — items under separate ancestors matching
		 * the selector become separate galleries. Ignored when `zoom` is `false`.
		 */
		zoomScope?: string | undefined
	}

const {
	alt,
	background,
	backgroundDark,
	class: classFromAstro,
	className: classFromJsx,
	creator,
	organization,
	showCredit,
	src,
	type,
	typeFallback = 'image',
	zoom,
	zoomScope,
	...imageProps
} = Astro.props

// Merge class from both Astro-style `class` and JSX-style `className` props
// (MDX may pass both; getImage() passes through `className` unfiltered)
const className = classFromAstro ?? classFromJsx

// Dev-only hint when a { dark, light } pair is passed — Image silently uses
// `.light`, but the user probably meant to reach for `<Picture>` instead.
if (import.meta.env.DEV && isDarkLightImageMetadata(src)) {
	console.warn(
		'[astro-media-kit] Image received a { dark, light } source — rendering the `.light` variant only. Use `<Picture>` for dark-mode image sources.',
	)
}

const { imageMetadata } = await resolveSrcToMetadata(src, undefined, {
	componentName: 'Image',
	darkDisabled: true,
})

// Handle responsive layout (same as Astro's Image)
const { merged: getImageProps, useResponsive } = mergeLayoutDefaults(imageProps, imageConfig)

// Clone src object to avoid Astro thinking the image is used outside optimization pipeline
const originalSrc = await resolveSrc(imageMetadata)
const clonedSrc = cloneImageMetadata(originalSrc)

// Transparency-aware fallback format: when the user doesn't pass `format`, pick
// one based on the input — `gif`/`svg`/`jpg`/`jpeg` stay in-format, others → png.
const outputFormat = pickFallbackFormat(imageProps.format, clonedSrc)

const image: GetImageResult = await getImage({
	...getImageProps,
	...compositingBackground(outputFormat, background),
	format: outputFormat,
	src: clonedSrc,
})

warnBackgroundDarkWithoutBackground(background, backgroundDark, 'Image')
warnWidthsWithoutSizes(
	imageMetadata.src,
	{
		densities: imageProps.densities ?? undefined,
		sizes: imageProps.sizes ?? undefined,
		widths: imageProps.widths ?? undefined,
	},
	useResponsive,
	'Image',
)

const { light: backgroundStyle } = buildBackgroundStyle({
	background,
	backgroundDark,
	isSelector: false,
})

// Assemble <img> attributes: let getImage's result attributes drive, pull
// `class` off (we merge it via class:list), and add our superset markers.
const imgAdditionalAttributes: HTMLAttributes<'img'> = {}
if (import.meta.env.DEV) {
	imgAdditionalAttributes['data-image-component'] = 'true'
}

const { class: imgClassName, ...imgAttributes } = {
	...imgAdditionalAttributes,
	...image.attributes,
}

const resolvedSizes = resolveSizesAttribute(
	imageProps.sizes,
	typeof imgAttributes.sizes === 'string' ? imgAttributes.sizes : undefined,
)
if (resolvedSizes !== undefined) {
	imgAttributes.sizes = resolvedSizes
}

const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: imageMetadata,
	type,
	typeFallback,
}
---

<Caption {...captionProps}>
	<Zoomer enabled={zoom} scope={zoomScope} slot="media-component">
		<img
			alt={alt}
			src={image.src}
			{...imgAttributes}
			class:list={[className, imgClassName, 'amk']}
			style={backgroundStyle}
		/>
	</Zoomer>
	<slot />
</Caption>
