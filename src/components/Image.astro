---
// Simple image component wrapping Astro's built-in Image.
// Accepts ImageMetadata or a string path. When given a { dark, light }
// pair (e.g. from a .tldr import), uses the light variant — use the
// Picture component for full dark mode support.

import type { ImageMetadata } from 'astro'
import type { LocalImageProps } from 'astro:assets'
import { Image as AstroImage } from 'astro:assets'
import type { DarkLightImageMetadata, ImageMetadataLike } from '../types'
import type { Props as CaptionProps } from './Caption.astro'
import Caption from './Caption.astro'
import {
	isDarkLightImageMetadata,
	isImageMetadataObject,
	resolveImageSource,
	unwrapImageMetadata,
} from './utils/image'
import Zoomer from './Zoomer.astro'
import './amk-image.css'

/** Props for the `<Image>` component — wraps Astro's `<Image>` with caption and zoom support. */
export type Props = Omit<CaptionProps, 'src'> &
	Omit<LocalImageProps, 'src'> & {
		/**
		 * CSS background color for the image (visible behind transparent areas).
		 */
		background?: string | undefined
		/**
		 * Dark mode background color override. Uses `light-dark()` with `background`.
		 */
		backgroundDark?: string | undefined
		/**
		 * Image source: an imported `ImageMetadata` object or an absolute file path string.
		 */
		src: DarkLightImageMetadata | ImageMetadata | ImageMetadataLike | string
		/**
		 * Enable PhotoSwipe zoom. `true` uses default gallery, a string groups into a named gallery.
		 * @default false
		 */
		zoom?: boolean | string | undefined
	}

const {
	background,
	backgroundDark,
	creator,
	organization,
	showCredit = true,
	src,
	type,
	typeFallback = 'image',
	zoom,
	...imageRestProps
} = Astro.props

// Resolve src — if it's still a string at this point, either the mediaKit() integration
// isn't registered (which auto-imports string paths), or it's an absolute filesystem path.
// Relative paths like "../assets/foo.jpg" only work with the auto-import integration.
if (typeof src === 'string' && (src.startsWith('./') || src.startsWith('../'))) {
	throw new Error(
		`Image received a relative string path "${src}". ` +
			'Add the mediaKit() integration to your astro.config to enable auto-importing, ' +
			'or import the image and pass the ImageMetadata object directly.',
	)
}

// When given a { dark, light } pair (e.g. from a .tldr import with autoDarkMode),
// use the light variant. For full dark mode support, use <Picture> instead.
const resolvedImage = isDarkLightImageMetadata(src)
	? src.light
	: isImageMetadataObject(src)
		? unwrapImageMetadata(src)
		: await resolveImageSource(src)

const imageMetadata = isDarkLightImageMetadata(resolvedImage) ? resolvedImage.light : resolvedImage

const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: imageMetadata,
	type,
	typeFallback,
}

// Build inline background-color style for transparent images
if (backgroundDark && !background) {
	console.warn(
		'[astro-media-kit] backgroundDark is set without background — light mode will be transparent.',
	)
}

let backgroundStyle: string | undefined
if (background && backgroundDark) {
	backgroundStyle = `color-scheme:light dark;background-color:light-dark(${background},${backgroundDark})`
} else if (backgroundDark) {
	backgroundStyle = `color-scheme:light dark;background-color:light-dark(transparent,${backgroundDark})`
} else if (background) {
	backgroundStyle = `background-color:${background}`
}

// Only pass background for compositing when the output format is opaque (JPEG)
const opaqueFormats = new Set(['jpeg', 'jpg'])
const outputFormat = imageRestProps.format ?? imageMetadata.format
const compositingBackground = background && opaqueFormats.has(outputFormat) ? { background } : {}

// Assemble props for AstroImage. The assertion is necessary because Astro's
// Image component accepts LocalImageProps | RemoteImageProps, and TypeScript's
// exactOptionalPropertyTypes can't reconcile spread props with union types.
// See: https://github.com/withastro/astro/issues/10780

// eslint-disable-next-line ts/consistent-type-assertions, ts/no-unsafe-type-assertion -- Astro #10780
const astroImageProps = {
	class: 'amk',
	src: imageMetadata,
	style: backgroundStyle,
	...compositingBackground,
	...imageRestProps,
} as LocalImageProps
---

<Caption {...captionProps}>
	<Zoomer slot="media-component" zoom={zoom}>
		<AstroImage {...astroImageProps} slot="media-component" />
	</Zoomer>
	<slot />
</Caption>
