---
// Simple image component wrapping Astro's built-in Image.
// Accepts ImageMetadata or a string path. When given a { dark, light }
// pair (e.g. from a .tldr import), uses the light variant — use the
// Picture component for full dark mode support.

import type { ImageMetadata } from 'astro'
import type { LocalImageProps } from 'astro:assets'
import { Image as AstroImage } from 'astro:assets'
import type { DarkLightImageMetadata } from '../types'
import type { Props as CaptionProps } from './Caption.astro'
import Caption from './Caption.astro'
import { isDarkLightImageMetadata, isImageMetadataObject, resolveImageSource } from './utils/image'

// Only use LocalImageProps since we always resolve to ImageMetadata (local images)
export type Props = Omit<CaptionProps, 'src'> &
	Omit<LocalImageProps, 'src'> & {
		src: DarkLightImageMetadata | ImageMetadata | string
	}

const {
	creator,
	organization,
	showCredit = true,
	src,
	type,
	typeFallback = 'image',
	...imageRestProps
} = Astro.props

// Resolve src — if it's still a string at this point, either the mediaKit() integration
// isn't registered (which auto-imports string paths), or it's an absolute filesystem path.
// Relative paths like "../assets/foo.jpg" only work with the auto-import integration.
if (typeof src === 'string' && (src.startsWith('./') || src.startsWith('../'))) {
	throw new Error(
		`Image received a relative string path "${src}". ` +
			'Add the mediaKit() integration to your astro.config to enable auto-importing, ' +
			'or import the image and pass the ImageMetadata object directly.',
	)
}

// When given a { dark, light } pair (e.g. from a .tldr import with autoDarkMode),
// use the light variant. For full dark mode support, use <Picture> instead.
const resolvedImage = isDarkLightImageMetadata(src)
	? src.light
	: isImageMetadataObject(src)
		? src
		: await resolveImageSource(src)

const imageMetadata = isDarkLightImageMetadata(resolvedImage) ? resolvedImage.light : resolvedImage

const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: imageMetadata,
	type,
	typeFallback,
}

// Assemble props for AstroImage. The assertion is necessary because Astro's
// Image component accepts LocalImageProps | RemoteImageProps, and TypeScript's
// exactOptionalPropertyTypes can't reconcile spread props with union types.
// See: https://github.com/withastro/astro/issues/10780
// eslint-disable-next-line ts/consistent-type-assertions, ts/no-unsafe-type-assertion -- Astro #10780
const astroImageProps = { src: imageMetadata, ...imageRestProps } as LocalImageProps
---

<Caption {...captionProps}>
	<AstroImage {...astroImageProps} slot="media-component" />
	<slot />
</Caption>
