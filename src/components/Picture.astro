---
// Custom Picture component with dark mode support.
// Renders <picture> directly using Astro's getImage() API (the same approach
// as Astro's built-in Picture.astro), extended with prefers-color-scheme
// media queries for light/dark image variants.

import type { ImageMetadata, ImageOutputFormat } from 'astro'
import type { HTMLAttributes } from 'astro/types'
import { getImage, imageConfig } from 'astro:assets'
import * as mime from 'mrmime'
import type { DarkLightImageMetadata, ImageMetadataLike } from '../types'
import type { Props as CaptionProps } from './Caption.astro'
import { needsBackgroundDarkVariant, opaqueFormats } from '../utilities/dark-variant'
import Caption from './Caption.astro'
import {
	isDarkLightImageMetadata,
	isImageMetadataObject,
	resolveImageSource,
	unwrapImageMetadata,
} from './utils/image'
import Zoomer from './Zoomer.astro'
import './amk-image.css'

type GetImageResult = Awaited<ReturnType<typeof getImage>>

const defaultFormats = ['webp'] as const
const defaultFallbackFormat = 'png' as const
const specialFormatsFallback = ['gif', 'svg', 'jpg', 'jpeg'] as const

// Inlined from Astro internals — trivial helpers, avoids importing from internal paths
function isESMImportedImage(src: ImageMetadata | string): src is ImageMetadata {
	return typeof src === 'object' || (typeof src === 'function' && 'src' in src)
}

async function resolveSrc(
	src: ImageMetadata | Promise<{ default: ImageMetadata }> | string,
): Promise<ImageMetadata | string> {
	if (typeof src === 'object' && 'then' in src) {
		const resolved = await src
		return resolved.default
	}

	return src
}

/** Props for the `<Picture>` component — renders `<picture>` with dark mode, responsive sources, and zoom. */
export type Props = {
	/**
	 * Alt text for the image. Required for accessibility.
	 */
	alt: string
	/**
	 * CSS background color for the image (visible behind transparent areas).
	 */
	background?: string | undefined
	/**
	 * Dark mode background color override. Uses `light-dark()` with `background`.
	 */
	backgroundDark?: string | undefined
	/**
	 * CSS class applied to the `<img>` element.
	 */
	class?: string | undefined
	/**
	 * Attribution name for the media creator. Overrides XMP-extracted creator.
	 */
	creator?: CaptionProps['creator']
	/**
	 * Dark mode switching strategy.
	 * - `'media'` (default): `prefers-color-scheme` media queries on `<source>` elements.
	 *   Follows the OS/browser color scheme preference.
	 * - `'none'`: disables all dark mode behavior (image sources and backgrounds).
	 * - Any other string: a CSS selector (e.g. `"[data-theme='dark']"`, `".dark"`) that
	 *   triggers dark mode. Renders two `<picture>` elements toggled via injected CSS.
	 *   Use this for frameworks like Starlight (`[data-theme='dark']`) or Tailwind (`.dark`)
	 *   that control dark mode via a class or attribute rather than the OS preference.
	 */
	darkMode?: 'media' | 'none' | (string & {})
	/**
	 * Image decoding hint.
	 * @default 'sync'
	 */
	decoding?: 'async' | 'auto' | 'sync' | undefined
	/**
	 * Pixel density descriptors for `srcset` (e.g. `[1, 2]` or `['1x', '2x']`).
	 */
	densities?: Array<`${number}x` | number> | undefined
	/**
	 * Format for the `<img>` fallback `src`.
	 * @default 'png'
	 */
	fallbackFormat?: ImageOutputFormat | undefined
	/**
	 * CSS `object-fit` value passed to Astro's image optimizer.
	 */
	fit?: string | undefined
	/**
	 * Output formats for `<source>` elements.
	 * @default ['webp']
	 */
	formats?: ImageOutputFormat[] | undefined
	/**
	 * Astro image layout mode.
	 * @default 'responsive'
	 */
	layout?: 'constrained' | 'fixed' | 'full-width' | 'none' | 'responsive' | undefined
	/**
	 * Lazy-loading behavior.
	 * @default 'lazy'
	 */
	loading?: 'eager' | 'lazy' | undefined
	/**
	 * Organization or publication to credit alongside the creator.
	 */
	organization?: CaptionProps['organization']
	/**
	 * HTML attributes spread onto the `<picture>` element.
	 */
	pictureAttributes?: HTMLAttributes<'picture'> | undefined
	/**
	 * CSS `object-position` value passed to Astro's image optimizer.
	 */
	position?: string | undefined
	/**
	 * Show the credit line in the caption.
	 * @default true
	 */
	showCredit?: CaptionProps['showCredit']
	/**
	 * `sizes` attribute for responsive images. Auto-generated when using `layout`.
	 */
	sizes?: string | undefined
	/**
	 * Image source: `ImageMetadata`, a `{ dark, light }` pair, or an absolute file path string.
	 */
	src: DarkLightImageMetadata | ImageMetadata | ImageMetadataLike | string
	/**
	 * Dark mode image variant. Rendered via `prefers-color-scheme` media query on `<source>`. Pass `false` to disable auto dark mode generation.
	 */
	srcDark?: boolean | ImageMetadata | ImageMetadataLike | string | undefined
	/**
	 * Semantic media type label (e.g. `'photo'`, `'screenshot'`). Shown in the credit line.
	 */
	type?: CaptionProps['type']
	/**
	 * Fallback media type when XMP Label tag is missing.
	 * @default 'image'
	 */
	typeFallback?: CaptionProps['typeFallback']
	/**
	 * Explicit widths (in pixels) for `srcset` generation.
	 */
	widths?: number[] | undefined
	/**
	 * Enable PhotoSwipe zoom. `true` uses default gallery, a string groups into a named gallery.
	 * @default false
	 */
	zoom?: boolean | string | undefined
}

const {
	alt,
	background,
	backgroundDark: backgroundDarkProp,
	class: className,
	creator,
	darkMode = 'media',
	fallbackFormat: fallbackFormatProp,
	formats: formatsProp,
	organization,
	pictureAttributes: pictureAttributesProp = {},
	showCredit,
	src,
	srcDark: srcDarkProp,
	type,
	typeFallback = 'image',
	zoom,
	...imageProps
} = Astro.props

// Dark mode strategy
const isSelector = darkMode !== 'media' && darkMode !== 'none'
const isNone = darkMode === 'none'

if (isSelector && /[{}<>;]/.test(darkMode)) {
	throw new Error(
		`Picture darkMode selector "${darkMode}" contains invalid characters. ` +
			'Provide a valid CSS selector (e.g. "[data-theme=\'dark\']", ".dark").',
	)
}

// When darkMode='none', suppress all dark behavior
const backgroundDark = isNone ? undefined : backgroundDarkProp

// Default decoding and loading — decoding: 'sync' prevents flashes, loading: 'lazy' defers offscreen images
imageProps.decoding ??= 'sync'
imageProps.loading ??= 'lazy'

// Resolve src — relative string paths only work with the mediaKit() auto-import integration.
function assertNotRelativePath(path: unknown): void {
	if (typeof path === 'string' && (path.startsWith('./') || path.startsWith('../'))) {
		throw new Error(
			`Picture received a relative string path "${path}". ` +
				'Add the mediaKit() integration to your astro.config to enable auto-importing, ' +
				'or import the image and pass the ImageMetadata object directly.',
		)
	}
}

assertNotRelativePath(src)

// Normalize srcDark: true/undefined = auto, false = disabled, other = explicit source
const darkDisabled = isNone || srcDarkProp === false
const srcDarkSource =
	typeof srcDarkProp === 'boolean' || srcDarkProp === undefined ? undefined : srcDarkProp
assertNotRelativePath(srcDarkSource)

let imageMetadata: ImageMetadata
let imageMetadataDark: ImageMetadata | undefined

if (isDarkLightImageMetadata(src)) {
	// { dark, light } object passed directly
	imageMetadata = src.light
	if (srcDarkSource) {
		imageMetadataDark = isImageMetadataObject(srcDarkSource)
			? unwrapImageMetadata(srcDarkSource)
			: // eslint-disable-next-line ts/no-unsafe-type-assertion -- resolveImageSource returns ImageMetadata when called without srcDark
				((await resolveImageSource(srcDarkSource)) as ImageMetadata)
	} else if (!darkDisabled) {
		imageMetadataDark = src.dark
	}
} else if (isImageMetadataObject(src)) {
	imageMetadata = unwrapImageMetadata(src)
	if (srcDarkSource) {
		imageMetadataDark = isImageMetadataObject(srcDarkSource)
			? unwrapImageMetadata(srcDarkSource)
			: // eslint-disable-next-line ts/no-unsafe-type-assertion -- resolveImageSource returns ImageMetadata when called without srcDark
				((await resolveImageSource(srcDarkSource)) as ImageMetadata)
	}
} else {
	// String path
	const resolved = srcDarkSource
		? await resolveImageSource(src, srcDarkSource)
		: await resolveImageSource(src)

	if (isDarkLightImageMetadata(resolved)) {
		imageMetadata = resolved.light
		imageMetadataDark = darkDisabled ? undefined : resolved.dark
	} else {
		imageMetadata = resolved
	}
}

// When input is SVG and user hasn't explicitly set formats, keep SVG format
// to preserve vector quality (converting SVG → webp defeats the purpose).
const formats =
	formatsProp ?? (imageMetadata.format === 'svg' ? (['svg'] as const) : defaultFormats)

// Props to pass to getImage
const getImageProps = {
	alt,
	...imageProps,
}

// Propagate scoped style class to picture element
const pictureAttributes = { ...pictureAttributesProp }
const scopedStyleClass = className?.match(/\bastro-\w{8}\b/)?.[0]
if (scopedStyleClass) {
	pictureAttributes.class = pictureAttributes.class
		? `${pictureAttributes.class} ${scopedStyleClass}`
		: scopedStyleClass
}

// Handle responsive layout (same as Astro's Picture)
const layout = imageProps.layout ?? imageConfig.layout ?? 'none'
const useResponsive = layout !== 'none'

if (useResponsive) {
	getImageProps.layout ??= imageConfig.layout
	getImageProps.fit ??= imageConfig.objectFit ?? 'cover'
	getImageProps.position ??= imageConfig.objectPosition ?? 'center'
} else if (imageConfig.objectFit ?? imageConfig.objectPosition) {
	getImageProps.fit ??= imageConfig.objectFit
	getImageProps.position ??= imageConfig.objectPosition
}

// Propagate data-astro-cid-* attributes to picture element
for (const key in getImageProps) {
	if (key.startsWith('data-astro-cid')) {
		// @ts-expect-error Astro island props aren't typed
		// eslint-disable-next-line ts/no-unsafe-type-assertion -- dynamic key access requires assertion
		pictureAttributes[key] = getImageProps[key as keyof typeof getImageProps]
	}
}

// Only pass background to getImage for opaque formats (JPEG) where transparency is lost
function compositingBackground(format: string, bg: string | undefined): Record<string, string> {
	return bg && opaqueFormats.has(format) ? { background: bg } : {}
}

// Generate optimized images for each format (light variant)
const originalSrc = await resolveSrc(imageMetadata)
const optimizedImages: GetImageResult[] = await Promise.all(
	formats.map(async (format) =>
		getImage({
			...getImageProps,
			...compositingBackground(format, background),
			densities: imageProps.densities,
			format,
			src: originalSrc,
			widths: imageProps.widths,
		}),
	),
)

// Generate optimized images for dark variant when:
// 1. A separate dark source image is provided (srcDark), or
// 2. backgroundDark differs from background on an opaque format (same source, different composited bg)
const needsDarkVariant =
	imageMetadataDark ?? needsBackgroundDarkVariant(formats, background, backgroundDark, darkDisabled)
let optimizedImagesDark: GetImageResult[] | undefined
if (needsDarkVariant) {
	const darkBackground = backgroundDark ?? background
	const originalSrcDark = imageMetadataDark ? await resolveSrc(imageMetadataDark) : originalSrc
	optimizedImagesDark = await Promise.all(
		formats.map(async (format) =>
			getImage({
				...getImageProps,
				...compositingBackground(format, darkBackground),
				densities: imageProps.densities,
				format,
				src: originalSrcDark,
				widths: imageProps.widths,
			}),
		),
	)
}

// Clone src object to avoid Astro thinking the image is used outside optimization pipeline
// eslint-disable-next-line ts/no-unsafe-assignment -- clone is a private undocumented prop
const clonedSrc = isESMImportedImage(originalSrc)
	? // @ts-expect-error clone is a private prop on ImageMetadata
		(originalSrc.clone ?? originalSrc)
	: originalSrc

// Determine fallback format
let resultFallbackFormat = fallbackFormatProp ?? defaultFallbackFormat
if (
	!fallbackFormatProp &&
	// eslint-disable-next-line ts/no-unsafe-argument -- clonedSrc type is narrowed by isESMImportedImage but ESLint doesn't see it
	isESMImportedImage(clonedSrc) &&
	(specialFormatsFallback as readonly string[]).includes(clonedSrc.format)
) {
	resultFallbackFormat = clonedSrc.format
}

// Generate fallback image (always light variant)
const fallbackImage = await getImage({
	...getImageProps,
	...compositingBackground(resultFallbackFormat, background),
	densities: imageProps.densities,
	format: resultFallbackFormat,
	src: originalSrc,
	widths: imageProps.widths,
})

const hasDarkMode = optimizedImagesDark !== undefined

// Generate dark fallback image for selector mode (needs its own <img> src)
let fallbackImageDark: GetImageResult | undefined
if (isSelector && hasDarkMode) {
	const darkBackground = backgroundDark ?? background
	const originalSrcDark = imageMetadataDark ? await resolveSrc(imageMetadataDark) : originalSrc
	fallbackImageDark = await getImage({
		...getImageProps,
		...compositingBackground(resultFallbackFormat, darkBackground),
		densities: imageProps.densities,
		format: resultFallbackFormat,
		src: originalSrcDark,
		widths: imageProps.widths,
	})
}

const imgAdditionalAttributes: HTMLAttributes<'img'> = {}
const sourceAdditionalAttributes: HTMLAttributes<'source'> = {}

if (imageProps.sizes) {
	sourceAdditionalAttributes.sizes = imageProps.sizes
}

if (fallbackImage.srcSet.values.length > 0) {
	imgAdditionalAttributes.srcset = fallbackImage.srcSet.attribute
}

if (import.meta.env.DEV) {
	imgAdditionalAttributes['data-image-component'] = 'true'
}

const { class: imgClassName, ...imgAttributes } = {
	...imgAdditionalAttributes,
	...fallbackImage.attributes,
}

// Build dark fallback img attributes for selector mode
let imgClassNameDark: string | undefined
let imgAttributesDark: Record<string, unknown> = {}
if (fallbackImageDark) {
	const imgAdditionalAttributesDark: HTMLAttributes<'img'> = {}
	if (fallbackImageDark.srcSet.values.length > 0) {
		imgAdditionalAttributesDark.srcset = fallbackImageDark.srcSet.attribute
	}

	if (import.meta.env.DEV) {
		imgAdditionalAttributesDark['data-image-component'] = 'true'
	}

	const { class: cls, ...attributes } = {
		...imgAdditionalAttributesDark,
		...fallbackImageDark.attributes,
	}
	imgClassNameDark = cls ?? undefined
	imgAttributesDark = attributes
}

const captionProps: CaptionProps = {
	creator,
	organization,
	showCredit,
	src: imageMetadata,
	type,
	typeFallback,
}

// Helper to build srcset attribute for a source
function buildSrcsetAttribute(image: GetImageResult): string {
	const { densities, widths } = imageProps
	if (densities ?? (!widths && !useResponsive)) {
		return `${image.src}${image.srcSet.values.length > 0 ? `, ${image.srcSet.attribute}` : ''}`
	}

	return image.srcSet.attribute
}

function getMimeType(image: GetImageResult): string {
	return mime.lookup(image.options.format ?? image.src) ?? `image/${image.options.format}`
}

// Build inline background-color style for transparent images
if (backgroundDark && !background) {
	console.warn(
		'[astro-media-kit] backgroundDark is set without background — light mode will be transparent.',
	)
}

let backgroundStyle: string | undefined
let backgroundStyleDark: string | undefined
if (isSelector) {
	// Selector mode: each <img> gets its own plain background-color
	if (background) backgroundStyle = `background-color:${background}`
	const darkBg = backgroundDark ?? background
	if (darkBg) backgroundStyleDark = `background-color:${darkBg}`
} else {
	// Media mode (and none mode, where backgroundDark is already undefined)
	// eslint-disable-next-line no-lonely-if
	if (background && backgroundDark) {
		backgroundStyle = `color-scheme:light dark;background-color:light-dark(${background},${backgroundDark})`
	} else if (backgroundDark) {
		backgroundStyle = `color-scheme:light dark;background-color:light-dark(transparent,${backgroundDark})`
	} else if (background) {
		backgroundStyle = `background-color:${background}`
	}
}

// Build injected <style> for selector mode
let selectorStyle: string | undefined
if (isSelector && hasDarkMode) {
	selectorStyle = `<style>picture.amk-dark{display:none}${darkMode} picture.amk-dark{display:block}${darkMode} picture.amk-light{display:none}</style>`
}
---

{selectorStyle && <Fragment set:html={selectorStyle} />}
<Caption {...captionProps}>
	<Zoomer slot="media-component" zoom={zoom}>
		{
			isSelector ? (
				<div {...pictureAttributes} slot="media-component">
					{hasDarkMode && (
						<picture class="amk-dark">
							{optimizedImagesDark!.map((image) => (
								<source
									srcset={buildSrcsetAttribute(image)}
									type={getMimeType(image)}
									{...sourceAdditionalAttributes}
								/>
							))}
							<img
								alt=""
								aria-hidden="true"
								src={fallbackImageDark!.src}
								{...imgAttributesDark}
								class:list={[imgClassNameDark, 'amk']}
								style={backgroundStyleDark}
							/>
						</picture>
					)}
					<picture class="amk-light">
						{optimizedImages.map((image) => (
							<source
								srcset={buildSrcsetAttribute(image)}
								type={getMimeType(image)}
								{...sourceAdditionalAttributes}
							/>
						))}
						<img
							alt={alt}
							src={fallbackImage.src}
							{...imgAttributes}
							class:list={[imgClassName, 'amk']}
							style={backgroundStyle}
						/>
					</picture>
				</div>
			) : (
				<picture {...pictureAttributes} slot="media-component">
					{hasDarkMode &&
						optimizedImagesDark!.map((image) => (
							<source
								media="(prefers-color-scheme: dark)"
								srcset={buildSrcsetAttribute(image)}
								type={getMimeType(image)}
								{...sourceAdditionalAttributes}
							/>
						))}
					{optimizedImages.map((image) => (
						<source
							media={hasDarkMode ? '(prefers-color-scheme: light)' : undefined}
							srcset={buildSrcsetAttribute(image)}
							type={getMimeType(image)}
							{...sourceAdditionalAttributes}
						/>
					))}
					<img
						alt={alt}
						src={fallbackImage.src}
						{...imgAttributes}
						class:list={[imgClassName, 'amk']}
						style={backgroundStyle}
					/>
				</picture>
			)
		}
	</Zoomer>
	<slot />
</Caption>
