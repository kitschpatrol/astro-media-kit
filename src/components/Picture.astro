---
// Reimplements Astro's `<Picture>` component as a clean superset of the built-in:
// - Dark mode (via prefers-color-scheme media queries, or a custom selector)
// - Transparency-aware fallback format selection
// - Responsive srcset mirroring the `sizes` attribute onto each <source>
// - Background compositing for opaque output formats
// - Caption + Zoom wrappers from the media-kit
//
// Remote image sources are intentionally not supported — pass a local
// ImageMetadata object, a { dark, light } pair, or an absolute file path.

import type { ImageMetadata, ImageOutputFormat } from 'astro'
import type { LocalImageProps } from 'astro:assets'
import type { HTMLAttributes } from 'astro/types'
import { getImage, imageConfig } from 'astro:assets'
import type { DarkLightImageMetadata, ImageMetadataLike } from '../types'
import type { PrefixedProps as PrefixedCaptionProps, Props as CaptionProps } from './Caption.astro'
import type { GetImageResult } from './utils/image-orchestration'
import Caption from './Caption.astro'
import {
	buildBackgroundStyle,
	buildSrcsetAttribute,
	cloneImageMetadata,
	compositingBackground,
	defaultFormats,
	extractScopedStyleClass,
	getMimeType,
	mergeLayoutDefaults,
	needsBackgroundDarkVariant,
	pickFallbackFormat,
	propagateAstroCidAttributes,
	resolveSizesAttribute,
	resolveSrc,
	resolveSrcToMetadata,
	warnBackgroundDarkWithoutBackground,
	warnWidthsWithoutSizes,
} from './utils/image-orchestration'
import Zoomer from './Zoomer.astro'

/**
 * Props for the `<Picture>` component — renders `<picture>` with dark mode,
 * responsive sources, and zoom. Derives from Astro's `LocalImageProps` (all
 * getImage-compatible fields like `densities`, `fit`, `height`, `layout`,
 * `loading`, `position`, `quality`, `sizes`, `width`, `widths`, plus `<img>`
 * HTMLAttributes) and mirrors the `formats` / `fallbackFormat` /
 * `pictureAttributes` extras Astro's `<Picture>` adds on top. Media-kit
 * extensions (`src` widening, dark mode, background, caption, zoom) follow.
 */
export type Props = PrefixedCaptionProps &
	Omit<LocalImageProps, 'height' | 'src' | 'width'> & {
		/**
		 * CSS background color for the image (visible behind transparent areas).
		 */
		background?: string | undefined
		/**
		 * Dark mode background color override. Uses `light-dark()` with `background`.
		 */
		backgroundDark?: string | undefined
		/**
		 * JSX-style class name (passed by MDX). Merged with `class`.
		 */
		className?: string | undefined
		/**
		 * Dark mode switching strategy.
		 * - `'media'` (default): `prefers-color-scheme` media queries on `<source>` elements.
		 *   Follows the OS/browser color scheme preference.
		 * - `'none'`: disables all dark mode behavior (image sources and backgrounds).
		 * - Any other string: a CSS selector (e.g. `"[data-theme='dark']"`, `".dark"`) that
		 *   triggers dark mode. Renders two `<picture>` elements toggled via injected CSS.
		 *   Use this for frameworks like Starlight (`[data-theme='dark']`) or Tailwind (`.dark`)
		 *   that control dark mode via a class or attribute rather than the OS preference.
		 */
		darkMode?: 'media' | 'none' | (string & {})
		/**
		 * Format for the `<img>` fallback `src`. Defaults to `'png'`, or the input
		 * format itself when the input is `gif`, `svg`, `jpg`, or `jpeg` (so we
		 * don't flatten animations, rasterize vectors, or double-encode JPEGs).
		 */
		fallbackFormat?: ImageOutputFormat | undefined
		/**
		 * Output formats for `<source>` elements.
		 * @default ['webp']
		 */
		formats?: ImageOutputFormat[] | undefined
		/**
		 * Display height in pixels. Narrowed from Astro's `<img>` HTMLAttributes to
		 * numeric-only, since getImage() rejects string dimensions.
		 */
		height?: number | undefined
		/**
		 * HTML attributes spread onto the outer `<picture>` (or wrapping `<div>` in selector mode).
		 */
		pictureAttributes?: HTMLAttributes<'picture'> | undefined
		/**
		 * Image source: `ImageMetadata`, a `{ dark, light }` pair, or an absolute file path string.
		 */
		src: DarkLightImageMetadata | ImageMetadata | ImageMetadataLike | string
		/**
		 * Dark mode image variant. Rendered via `prefers-color-scheme` media query on `<source>`. Pass `false` to disable auto dark mode generation.
		 */
		srcDark?: boolean | ImageMetadata | ImageMetadataLike | string | undefined
		/**
		 * Display width in pixels. Narrowed from Astro's `<img>` HTMLAttributes to
		 * numeric-only, since getImage() rejects string dimensions.
		 */
		width?: number | undefined
		/**
		 * Enable PhotoSwipe zoom. `true` uses default gallery, a string groups into a named gallery.
		 * @default false
		 */
		zoom?: boolean | string | undefined
		/**
		 * CSS selector defining a gallery scope boundary. When set, galleries cannot
		 * form across matching ancestors — items under separate ancestors matching
		 * the selector become separate galleries. Ignored when `zoom` is `false`.
		 */
		zoomScope?: string | undefined
	}

const {
	alt,
	background,
	backgroundDark: backgroundDarkProp,
	captionCreator,
	captionOrganization,
	captionShowCredit,
	captionType,
	captionTypeFallback = 'image',
	class: classFromAstro,
	className: classFromJsx,
	darkMode = 'media',
	fallbackFormat: fallbackFormatProp,
	formats: formatsProp,
	pictureAttributes: pictureAttributesProp = {},
	src,
	srcDark: srcDarkProp,
	zoom,
	zoomScope,
	...imageProps
} = Astro.props

// Merge class from both Astro-style `class` and JSX-style `className` props
// (MDX may pass both; getImage() passes through `className` unfiltered)
const className = classFromAstro ?? classFromJsx

// Dark mode strategy
const isSelector = darkMode !== 'media' && darkMode !== 'none'
const isNone = darkMode === 'none'

if (isSelector && /[{}<>;]/.test(darkMode)) {
	throw new Error(
		`Picture darkMode selector "${darkMode}" contains invalid characters. ` +
			'Provide a valid CSS selector (e.g. "[data-theme=\'dark\']", ".dark").',
	)
}

// When darkMode='none', suppress all dark behavior
const backgroundDark = isNone ? undefined : backgroundDarkProp

// Normalize srcDark: true/undefined = auto, false = disabled, other = explicit source
const darkDisabled = isNone || srcDarkProp === false
const srcDarkSource = isNone
	? undefined
	: typeof srcDarkProp === 'boolean' || srcDarkProp === undefined
		? undefined
		: srcDarkProp

const { imageMetadata, imageMetadataDark } = await resolveSrcToMetadata(src, srcDarkSource, {
	componentName: 'Picture',
	darkDisabled,
})

// When input is SVG and user hasn't explicitly set formats, keep SVG format
// to preserve vector quality (converting SVG → webp defeats the purpose).
const formats =
	formatsProp ?? (imageMetadata.format === 'svg' ? (['svg'] as const) : defaultFormats)

// Propagate scoped style class to picture element
const pictureAttributes = { ...pictureAttributesProp }
const scopedStyleClass = extractScopedStyleClass(className)
if (scopedStyleClass) {
	pictureAttributes.class = pictureAttributes.class
		? `${pictureAttributes.class} ${scopedStyleClass}`
		: scopedStyleClass
}

// Handle responsive layout (same as Astro's Picture)
const { merged: getImageProps, useResponsive } = mergeLayoutDefaults(imageProps, imageConfig)

// Propagate data-astro-cid-* attributes to picture element
propagateAstroCidAttributes(getImageProps, pictureAttributes)

// Generate optimized images for each format (light variant)
const originalSrc = await resolveSrc(imageMetadata)
const optimizedImages: GetImageResult[] = await Promise.all(
	formats.map(async (format) =>
		getImage({
			...getImageProps,
			...compositingBackground(format, background),
			densities: imageProps.densities,
			format,
			src: originalSrc,
			widths: imageProps.widths,
		}),
	),
)

// Generate optimized images for dark variant when:
// 1. A separate dark source image is provided (srcDark), or
// 2. backgroundDark differs from background on an opaque format (same source, different composited bg)
const needsDarkVariant =
	imageMetadataDark ?? needsBackgroundDarkVariant(formats, background, backgroundDark, darkDisabled)
let optimizedImagesDark: GetImageResult[] | undefined
if (needsDarkVariant) {
	const darkBackground = backgroundDark ?? background
	const originalSrcDark = imageMetadataDark ? await resolveSrc(imageMetadataDark) : originalSrc
	optimizedImagesDark = await Promise.all(
		formats.map(async (format) =>
			getImage({
				...getImageProps,
				...compositingBackground(format, darkBackground),
				densities: imageProps.densities,
				format,
				src: originalSrcDark,
				widths: imageProps.widths,
			}),
		),
	)
}

// Clone src object to avoid Astro thinking the image is used outside optimization pipeline
const clonedSrc = cloneImageMetadata(originalSrc)

// Determine fallback format (transparency-aware)
const resultFallbackFormat = pickFallbackFormat(fallbackFormatProp, clonedSrc)

// Generate fallback image (always light variant)
const fallbackImage = await getImage({
	...getImageProps,
	...compositingBackground(resultFallbackFormat, background),
	densities: imageProps.densities,
	format: resultFallbackFormat,
	src: originalSrc,
	widths: imageProps.widths,
})

const hasDarkMode = optimizedImagesDark !== undefined

// Generate dark fallback image for selector mode (needs its own <img> src)
let fallbackImageDark: GetImageResult | undefined
if (isSelector && hasDarkMode) {
	const darkBackground = backgroundDark ?? background
	const originalSrcDark = imageMetadataDark ? await resolveSrc(imageMetadataDark) : originalSrc
	fallbackImageDark = await getImage({
		...getImageProps,
		...compositingBackground(resultFallbackFormat, darkBackground),
		densities: imageProps.densities,
		format: resultFallbackFormat,
		src: originalSrcDark,
		widths: imageProps.widths,
	})
}

const imgAdditionalAttributes: HTMLAttributes<'img'> = {}
const sourceAdditionalAttributes: HTMLAttributes<'source'> = {}

// Mirror the `sizes` attribute onto <source> elements. Astro's getImage()
// emits `sizes` on `fallbackImage.attributes` for responsive layouts, but the
// <img> fallback never wins once a <source> matches. Without `sizes` on the
// source, the browser defaults to `100vw` and always picks the largest
// candidate from a width-descriptor srcset.
const fallbackSizes =
	typeof fallbackImage.attributes.sizes === 'string' ? fallbackImage.attributes.sizes : undefined
const effectiveSizes = resolveSizesAttribute(imageProps.sizes, fallbackSizes)
if (effectiveSizes) {
	sourceAdditionalAttributes.sizes = effectiveSizes
}

if (fallbackImage.srcSet.values.length > 0) {
	imgAdditionalAttributes.srcset = fallbackImage.srcSet.attribute
}

if (import.meta.env.DEV) {
	imgAdditionalAttributes['data-image-component'] = 'true'
}

const { class: imgClassName, ...imgAttributes } = {
	...imgAdditionalAttributes,
	...fallbackImage.attributes,
}

// Mirror the resolved sizes (with "auto, " prefix for auto-generated values)
// onto the <img> fallback too.
if (effectiveSizes !== undefined) {
	imgAttributes.sizes = effectiveSizes
}

// Build dark fallback img attributes for selector mode
let imgClassNameDark: string | undefined
let imgAttributesDark: Record<string, unknown> = {}
if (fallbackImageDark) {
	const imgAdditionalAttributesDark: HTMLAttributes<'img'> = {}
	if (fallbackImageDark.srcSet.values.length > 0) {
		imgAdditionalAttributesDark.srcset = fallbackImageDark.srcSet.attribute
	}

	if (import.meta.env.DEV) {
		imgAdditionalAttributesDark['data-image-component'] = 'true'
	}

	const { class: cls, ...attributes } = {
		...imgAdditionalAttributesDark,
		...fallbackImageDark.attributes,
	}
	if (effectiveSizes !== undefined) {
		attributes.sizes = effectiveSizes
	}
	imgClassNameDark = cls ?? undefined
	imgAttributesDark = attributes
}

const captionProps: CaptionProps = {
	creator: captionCreator,
	organization: captionOrganization,
	showCredit: captionShowCredit,
	src: imageMetadata,
	type: captionType,
	typeFallback: captionTypeFallback,
}

warnBackgroundDarkWithoutBackground(background, backgroundDark, 'Picture')
warnWidthsWithoutSizes(
	imageMetadata.src,
	{
		densities: imageProps.densities ?? undefined,
		sizes: imageProps.sizes ?? undefined,
		widths: imageProps.widths ?? undefined,
	},
	useResponsive,
	'Picture',
)

const { dark: backgroundStyleDark, light: backgroundStyle } = buildBackgroundStyle({
	background,
	backgroundDark,
	isSelector,
})

// Template-level srcset helper — closes over the relevant props so the template stays tidy
const srcsetFor = (image: GetImageResult): string =>
	buildSrcsetAttribute(image, imageProps, useResponsive)

// Build injected <style> for selector mode
let selectorStyle: string | undefined
if (isSelector && hasDarkMode) {
	selectorStyle = `<style>picture.amk-dark{display:none}${darkMode} picture.amk-dark{display:block}${darkMode} picture.amk-light{display:none}</style>`
}
---

{selectorStyle && <Fragment set:html={selectorStyle} />}
<Caption {...captionProps}>
	<Zoomer enabled={zoom} scope={zoomScope} slot="media-component">
		{
			isSelector ? (
				<div {...pictureAttributes}>
					{hasDarkMode && (
						<picture class="amk-dark">
							{optimizedImagesDark!.map((image) => (
								<source
									srcset={srcsetFor(image)}
									type={getMimeType(image)}
									{...sourceAdditionalAttributes}
								/>
							))}
							<img
								alt=""
								aria-hidden="true"
								src={fallbackImageDark!.src}
								{...imgAttributesDark}
								class:list={[className, imgClassNameDark, 'amk']}
								style={backgroundStyleDark}
							/>
						</picture>
					)}
					<picture class="amk-light">
						{optimizedImages.map((image) => (
							<source
								srcset={srcsetFor(image)}
								type={getMimeType(image)}
								{...sourceAdditionalAttributes}
							/>
						))}
						<img
							alt={alt}
							src={fallbackImage.src}
							{...imgAttributes}
							class:list={[className, imgClassName, 'amk']}
							style={backgroundStyle}
						/>
					</picture>
				</div>
			) : (
				<picture {...pictureAttributes}>
					{hasDarkMode &&
						optimizedImagesDark!.map((image) => (
							<source
								media="(prefers-color-scheme: dark)"
								srcset={srcsetFor(image)}
								type={getMimeType(image)}
								{...sourceAdditionalAttributes}
							/>
						))}
					{optimizedImages.map((image) => (
						<source
							media={hasDarkMode ? '(prefers-color-scheme: light)' : undefined}
							srcset={srcsetFor(image)}
							type={getMimeType(image)}
							{...sourceAdditionalAttributes}
						/>
					))}
					<img
						alt={alt}
						src={fallbackImage.src}
						{...imgAttributes}
						class:list={[className, imgClassName, 'amk']}
						style={backgroundStyle}
					/>
				</picture>
			)
		}
	</Zoomer>
	<slot />
</Caption>
