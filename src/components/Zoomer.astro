---
import { extractZoomTarget } from './utils/image'

type VideoElementTag = 'hls-video' | 'video' | 'vimeo-video' | 'youtube-video'

/** Props for the `<Zoomer>` component — PhotoSwipe-based image zoom wrapper. */
type Props = {
	videoConfig?: string | undefined
	videoElement?: undefined | VideoElementTag
	videoHeight?: number | undefined
	videoPoster?: string | undefined
	videoSrc?: string | undefined
	videoWidth?: number | undefined
	/**
	 * Enable zoom. `true` uses default gallery, a string groups images into a named gallery.
	 * @default false
	 */
	zoom?: boolean | string | undefined
}

const {
	videoConfig,
	videoElement,
	videoHeight,
	videoPoster,
	videoSrc,
	videoWidth,
	zoom = false,
} = Astro.props

const isVideo = videoElement !== undefined

let mediaComponentHtml = ''
let zoomUrl = ''
let zoomWidth = 0
let zoomHeight = 0
let zoomSrcset = ''
let galleryName: string | undefined

if (zoom) {
	if (!Astro.slots.has('media-component')) {
		throw new Error('Zoomer component requires a media-component slot when zoom is enabled.')
	}

	mediaComponentHtml = await Astro.slots.render('media-component')

	if (typeof zoom === 'string') {
		galleryName = zoom
	}

	if (isVideo) {
		zoomWidth = videoWidth ?? 1920
		zoomHeight = videoHeight ?? 1080
	} else {
		const target = extractZoomTarget(mediaComponentHtml)
		zoomUrl = target.url
		zoomWidth = target.width
		zoomHeight = target.height
		zoomSrcset = target.srcset
	}
}
---

{
	zoom ? (
		<>
			<>
				<script>
					import './utils/lightbox'
				</script>
				<style>
					a.pswp-zoom {
						cursor: zoom-in;
					}

					div.pswp-zoom {
						cursor: zoom-in;
					}
				</style>
				<style is:global>
					.pswp {
						--pswp-button-opacity: 0.5;
						--pswp-placeholder-bg: transparent;
						cursor: zoom-out;
					}

					.pswp--ui-visible .pswp__button--arrow,
					.pswp__button--close {
						opacity: var(--pswp-button-opacity);
						transition: opacity 0.2s ease;
					}

					.pswp__button--arrow:disabled {
						pointer-events: none;
						display: unset;
						opacity: 0;
						transition: opacity 0.2s ease;
					}

					.pswp__button--close {
						order: -1;
						margin-right: auto;
					}

					.pswp__button--arrow:hover,
					.pswp__button--close:hover {
						opacity: 1;
						transition: none;
					}
				</style>
			</>
			{isVideo ? (
				<div
					class="pswp-zoom"
					data-pswp-gallery={galleryName}
					data-pswp-height={zoomHeight}
					data-pswp-poster={videoPoster ?? ''}
					data-pswp-type="video"
					data-pswp-video-config={videoConfig}
					data-pswp-video-element={videoElement}
					data-pswp-video-src={videoSrc}
					data-pswp-width={zoomWidth}
				>
					<Fragment set:html={mediaComponentHtml} />
				</div>
			) : (
				<a
					class="pswp-zoom"
					data-pswp-gallery={galleryName}
					data-pswp-height={zoomHeight}
					data-pswp-srcset={zoomSrcset}
					data-pswp-width={zoomWidth}
					href={zoomUrl}
				>
					<Fragment set:html={mediaComponentHtml} />
				</a>
			)}
		</>
	) : (
		<slot name="media-component" />
	)
}
